<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FaceRecognitionApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FaceRecognitionApp"
    xmlns:views="clr-namespace:FaceRecognitionApp.Views"
    Title="Face Recognition"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Shell.FlyoutHeader>
        <Border Padding="20,40,20,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0"/>
                    <GradientStop Color="{StaticResource Accent}" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout Spacing="8">
                <Label Text="🔐"
                       FontSize="48"
                       HorizontalOptions="Center"/>
                <Label Text="Face Recognition"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Secure Identity System"
                       FontSize="14"
                       TextColor="White"
                       Opacity="0.9"
                       HorizontalTextAlignment="Center"/>
                <Label x:Name="AdminNameLabel"
                       FontSize="12"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Margin="0,12,0,0"
                       Opacity="0.8"/>
            </VerticalStackLayout>
        </Border>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <Button x:Name="LogoutButton"
                Text="➜] Logout"
                Clicked="OnLogoutClicked"
                BackgroundColor="#FF6B6B"
                TextColor="White"
                FontAttributes="Bold"
                Padding="16"
                CornerRadius="8"
                Margin="16,0,16,16"/>
    </Shell.FlyoutFooter>

    <ShellContent
        Title="Admin Login"
        ContentTemplate="{DataTemplate views:AdminLoginPage}"
        Route="login"/>

    <TabBar>
        <ShellContent
            Title="Home"
            Route="LandingPage"
            ContentTemplate="{DataTemplate views:LandingPage}">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="🏠"
                    FontFamily="OpenSansRegular"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"/>
            </ShellContent.Icon>
        </ShellContent>
        
        <ShellContent
            Title="Register"
            ContentTemplate="{DataTemplate views:UserRegistrationPage}"
            Route="registration">
            <ShellContent.Icon>
                <FontImageSource 
                    Glyph="➕" 
                    FontFamily="OpenSansRegular"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Verify"
            ContentTemplate="{DataTemplate views:FaceVerificationPage}"
            Route="FaceVerificationPage">
            <ShellContent.Icon>
                <FontImageSource 
                    Glyph="🔍" 
                    FontFamily="OpenSansRegular"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Employees"
            ContentTemplate="{DataTemplate views:UsersListPage}"
            Route="UsersListPage">
            <ShellContent.Icon>
                <FontImageSource 
                    Glyph="👥" 
                    FontFamily="OpenSansRegular"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"/>
            </ShellContent.Icon>
        </ShellContent>

    </TabBar>

</Shell>

