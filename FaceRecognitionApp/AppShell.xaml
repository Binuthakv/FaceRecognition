<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FaceRecognitionApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FaceRecognitionApp.Views"
    Title="Face Recognition"
    FlyoutBackgroundColor="{StaticResource Surface}"
    FlyoutWidth="300">

    <!-- ── FLYOUT HEADER ── -->
    <Shell.FlyoutHeader>
        <Border Padding="24,48,24,28"
                StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource PrimaryContainer}" Offset="0.0"/>
                    <GradientStop Color="{StaticResource Primary}"          Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <VerticalStackLayout Spacing="10">

                <Border BackgroundColor="#33FFFFFF"
                        StrokeShape="Ellipse"
                        Stroke="#44FFFFFF"
                        StrokeThickness="1"
                        WidthRequest="64"
                        HeightRequest="64"
                        HorizontalOptions="Center">
                    <Image Source="icon_lock.png"
                           HeightRequest="32" WidthRequest="32"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Label Text="AVIVANEXT"
                       FontSize="20"
                       FontAttributes="Bold"
                       CharacterSpacing="3"
                       TextColor="#FFFFFF"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Secure Identity System"
                       FontSize="12"
                       TextColor="#CCE8FF"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="1"/>

                <BoxView HeightRequest="1"
                         Color="#33FFFFFF"
                         Margin="0,8,0,0"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="●"
                           FontSize="8"
                           TextColor="#66FF99"
                           VerticalOptions="Center"/>
                    <!--
                        x:Name is intentionally omitted here.
                        Shell.FlyoutHeader is compiled as a separate DataTemplate,
                        so named children are not visible to the AppShell partial class.
                        Use this.FindByName<Label>("AdminNameLabel") in code-behind instead.
                    -->
                    <Label AutomationId="AdminNameLabel"
                           FontSize="12"
                           TextColor="#E0EFFF"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Shell.FlyoutHeader>

    <!-- ── SHELL RESOURCES ── -->
    <Shell.Resources>
        <Style TargetType="Grid" x:Key="FlyoutItemLayoutStyle" ApplyToDerivedTypes="True">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="#EBF2FF"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style TargetType="Label" x:Key="FlyoutItemLabelStyle">
            <Setter Property="TextColor"      Value="#424753"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>
    </Shell.Resources>

    <!-- ── FLYOUT FOOTER ── -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout Spacing="0">
            <BoxView HeightRequest="1"
                     Color="{StaticResource SurfaceVariant}"
                     Margin="16,0"/>
            <Button x:Name="LogoutButton"
                    Text="Sign Out"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FEF2F2"
                    TextColor="#BA1A1A"
                    BorderColor="#FECACA"
                    BorderWidth="1"
                    FontAttributes="Bold"
                    FontSize="14"
                    HeightRequest="52"
                    CornerRadius="14"
                    Margin="16,12,16,28"/>
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

    <!-- ── ROUTES ── -->
    <ShellContent
        Title="Admin Login"
        ContentTemplate="{DataTemplate views:AdminLoginPage}"
        Route="login"/>

    <TabBar>
        <ShellContent
            Title="Login"
            Route="AdminLoginPage"
            ContentTemplate="{DataTemplate views:AdminLoginPage}"/>
        <ShellContent
            Title="Home"
            Route="LandingPage"
            ContentTemplate="{DataTemplate views:LandingPage}"/>
        <ShellContent
            Title="Register"
            ContentTemplate="{DataTemplate views:UserRegistrationPage}"
            Route="RegistrationPage"/>
        <ShellContent
            Title="Verify"
            ContentTemplate="{DataTemplate views:FaceVerificationPage}"
            Route="FaceVerificationPage"/>
        <ShellContent
            Title="Employees"
            ContentTemplate="{DataTemplate views:UsersListPage}"
            Route="UsersListPage"/>
    </TabBar>

</Shell>
