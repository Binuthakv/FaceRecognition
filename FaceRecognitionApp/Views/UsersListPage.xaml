<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             xmlns:models="clr-namespace:FaceRecognitionApp.Models"
             x:Class="FaceRecognitionApp.Views.UsersListPage"
             x:DataType="viewmodels:UsersListViewModel"
             Title=""
             BackgroundColor="#F7F9FF"
             Shell.NavBarIsVisible="False"
Shell.TabBarIsVisible="False">

    
    <ContentPage.Resources>

        <!-- ── Primary filled button (Add User) ── -->
        <Style x:Key="AddUserButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#2E6FD8"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="52"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <!-- ── Surface filled button (Refresh) ── -->
        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#DEE3EB"/>
            <Setter Property="TextColor" Value="#171C22"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="52"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <!-- ── Edit icon button ── -->
        <Style x:Key="EditIconButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="#424753"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="WidthRequest" Value="36"/>
            <Setter Property="HeightRequest" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- ── Delete icon button ── -->
        <Style x:Key="DeleteIconButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="#BA1A1A"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="WidthRequest" Value="36"/>
            <Setter Property="HeightRequest" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Spacing="0">

            <Grid ColumnDefinitions="Auto,*"
                  BackgroundColor="#FFFFFF"
                  Padding="20,16"
                  ColumnSpacing="12">

                <Border Grid.Column="0"
                        BackgroundColor="#EFF6FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">

                    <Image Source="arrow_back.png"
                           HeightRequest="18"
                           WidthRequest="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">

                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                        </Image.GestureRecognizers>

                    </Image>

                </Border>

                <Label Grid.Column="1"
                       Text="AVIVANEXT"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#0056BB"
                       CharacterSpacing="2"
                       VerticalOptions="Center"/>

            </Grid>
            
            <VerticalStackLayout Padding="24,24,24,8"
                                 Spacing="4"
                                 HorizontalOptions="Center">
                <Label Text="Registered Users"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#2E6FD8"
                       HorizontalOptions="Center"/>
                <Label Text="Manage organizational access and biometric profiles."
                       FontSize="13"
                       TextColor="#424753"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Border BackgroundColor="#FFFFFF"
                    Stroke="#C2C6D5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="20"
                    Margin="20,12,20,0">
                <Grid ColumnDefinitions="*,Auto">

                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="SYSTEM ANALYTICS"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#424753"
                               CharacterSpacing="2"/>
                        <Label Text="Total Users"
                               FontSize="13"
                               TextColor="#424753"/>
                        <Label Text="{Binding TotalUsers}"
                               FontSize="36"
                               FontAttributes="Bold"
                               TextColor="#2E6FD8"/>
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            BackgroundColor="#EFF6FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24"
                            WidthRequest="48"
                            HeightRequest="48"
                            VerticalOptions="Center">
                        <Image Source="icon_users1.png"
                               HeightRequest="30"
                               WidthRequest="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Padding="20,12,20,0">
                <Button Grid.Column="0"
                        Text="Add User"
                        ImageSource="add_user.png"
                        ContentLayout="Left,8"
                        Style="{StaticResource AddUserButton}"
                        Command="{Binding AddUserCommand}"/>
                <Button Grid.Column="1"
                        Text="Refresh"
                        ImageSource="refresh.png"
                        Style="{StaticResource RefreshButton}"
                        Command="{Binding RefreshUsersCommand}"/>
            </Grid>

            <Label Text="USER DIRECTORY"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#424753"
                   CharacterSpacing="2"
                   Margin="24,16,24,4"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#2E6FD8"
                               HeightRequest="32"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"/>

            <Label Text="{Binding StatusMessage}"
                   FontSize="12"
                   TextColor="{Binding StatusColor}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="20,4,20,4"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}"/>

        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshUsersCommand}">

            <CollectionView ItemsSource="{Binding Users}"
                            SelectionMode="None"
                            Margin="0,0,0,16">

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12"
                                         Padding="40">
                        <Image Source="icon_person.png"
                               HeightRequest="52"
                               WidthRequest="52"
                               HorizontalOptions="Center"/>
                        <Label Text="No users registered yet"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#424753"
                               HorizontalOptions="Center"/>
                        <Label Text="Tap Add User to register the first user"
                               FontSize="13"
                               TextColor="#727784"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:UserRegistration">

                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#C2C6D5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                Margin="20,0,20,10">

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">

                                <Border Grid.Column="0"
                                        StrokeThickness="1"
                                        Stroke="#C2C6D5"
                                        StrokeShape="RoundRectangle 12"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        VerticalOptions="Center">
                                    <Image Source="{Binding Photo1, Converter={StaticResource ByteArrayToImageConverter}}"
                                           Aspect="AspectFill"
                                           WidthRequest="56"
                                           HeightRequest="56"/>
                                </Border>

                                <!-- ── USER DETAILS ── -->
                                <!-- Matches: h4 name + ID / Age / Enrolled spans -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">

                                    <Label Text="{Binding Name}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#2E6FD8"
                                           LineBreakMode="TailTruncation"/>

                                    <Label Text="{Binding UserId, StringFormat='ID: {0}'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#424753"
                                           CharacterSpacing="1"/>

                                    <Label Text="{Binding Age, StringFormat='Age: {0}'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#424753"
                                           CharacterSpacing="1"/>

                                    <Label Text="{Binding RegisteredDate, StringFormat='Enrolled: {0:MMM dd, yyyy}'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#424753"
                                           CharacterSpacing="1"/>

                                </VerticalStackLayout>

                                <!-- ── EDIT / DELETE BUTTONS ── -->
                                <!-- Matches: div.flex.flex-col.gap-2 edit + delete icon buttons -->
                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="4"
                                                     VerticalOptions="Center">

                                    <Button Text="✏️"
                                            Style="{StaticResource EditIconButton}"
                                            Command="{Binding BindingContext.EditUserCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}"/>

                                    <Button Text="🗑️"
                                            Style="{StaticResource DeleteIconButton}"
                                            Command="{Binding BindingContext.DeleteUserCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}"/>

                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
