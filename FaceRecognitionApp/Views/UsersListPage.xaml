<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             xmlns:models="clr-namespace:FaceRecognitionApp.Models"
             x:Class="FaceRecognitionApp.Views.UsersListPage"
             x:DataType="viewmodels:UsersListViewModel"
             Title="Registered Users"
             BackgroundColor="{StaticResource Surface}"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ── TOP APP BAR ── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource SurfaceContainerLowest}"
                StrokeShape="Rectangle"
                Stroke="Transparent"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                    <Image Source="arrow_back.png"
                           HeightRequest="18" WidthRequest="18"
                           HorizontalOptions="Center" VerticalOptions="Center">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
                <Label Grid.Column="1"
                       Text="AVIVANEXT"
                       FontFamily="Inter"
                       FontAttributes="Bold"
                       FontSize="16"
                       CharacterSpacing="2"
                       TextColor="{StaticResource Primary}"
                       VerticalOptions="Center"
                       Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── BODY ── -->
        <Grid Grid.Row="1" RowDefinitions="*">

            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshUsersCommand}">
                <ScrollView>
                    <VerticalStackLayout Padding="16,16,16,32" Spacing="20">

                        <!-- Page heading -->
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,4,0,0">
                            <Label Text="Registered Users"
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="20"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Manage organizational access and biometric profiles."
                                   FontFamily="Inter"
                                   FontSize="13"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <!-- System analytics card -->
                        <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                                StrokeShape="RoundRectangle 20"
                                Stroke="#33C2C6D5"
                                StrokeThickness="1"
                                Padding="20,18">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="14">
                                <Label Text="SYSTEM ANALYTICS"
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="10"
                                       CharacterSpacing="3"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Total Users"
                                               FontFamily="Inter"
                                               FontSize="13"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                        <Label Text="{Binding TotalUsers}"
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="36"
                                               TextColor="{StaticResource Primary}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#1A2E6FD8"
                                            StrokeShape="RoundRectangle 24"
                                            Stroke="Transparent"
                                            WidthRequest="48" HeightRequest="48"
                                            VerticalOptions="Center">
                                        <Image Source="icon_users1.png"
                                               HeightRequest="30" WidthRequest="30"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Add user / Refresh buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="＋  Add User"
                                    Command="{Binding AddUserCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource OnPrimary}"
                                    FontFamily="Inter"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CornerRadius="12"
                                    HeightRequest="52">
                                <Button.Shadow>
                                    <Shadow Brush="#2E6FD8" Offset="0,4" Radius="10" Opacity="0.22"/>
                                </Button.Shadow>
                            </Button>
                            <Button Grid.Column="1"
                                    Text="↺  Refresh"
                                    Command="{Binding RefreshUsersCommand}"
                                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                                    TextColor="{StaticResource OnSurface}"
                                    FontFamily="Inter"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CornerRadius="12"
                                    HeightRequest="52"
                                    BorderColor="#33C2C6D5"
                                    BorderWidth="1"/>
                        </Grid>

                        <!-- User directory -->
                        <VerticalStackLayout Spacing="10">
                            <!-- USER DIRECTORY header row: label + count badge -->
                            <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                <Label Grid.Column="0"
                                       Text="USER DIRECTORY"
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="10"
                                       CharacterSpacing="3"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       VerticalOptions="Center"/>
                                <!-- Live count pill -->
                                <Border Grid.Column="1"
                                        BackgroundColor="#1A2E6FD8"
                                        StrokeShape="RoundRectangle 20"
                                        Stroke="#332E6FD8"
                                        StrokeThickness="1"
                                        Padding="10,3"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding TotalUsers, StringFormat='{0} enrolled'}"
                                           FontFamily="Inter"
                                           FontAttributes="Bold"
                                           FontSize="10"
                                           CharacterSpacing="0.5"
                                           TextColor="{StaticResource Primary}"/>
                                </Border>
                            </Grid>

                            <!-- ── SEARCH BAR ── -->
                            <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="#882E6FD8"
                                    StrokeThickness="1.5"
                                    Padding="0"
                                    Margin="0,4,0,0">
                                <Border.Shadow>
                                    <Shadow Brush="#2E6FD8" Offset="0,4" Radius="14" Opacity="0.13"/>
                                </Border.Shadow>

                                <!-- Columns: 4 (accent) | * (entry) | 52 (icon button) -->
                                <Grid ColumnDefinitions="4,*,52" ColumnSpacing="0">

                                    <!-- ① Left blue accent strip -->
                                    <BoxView Grid.Column="0"
                                             WidthRequest="4"
                                             CornerRadius="16,0,0,16"
                                             VerticalOptions="Fill"/>

                                    <!-- ② Text input -->
                                    <Entry Grid.Column="1"
                                           x:Name="SearchEntry"
                                           Text="{Binding SearchText}"
                                           Placeholder="Search by Name, ID, Age"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource OnSurfaceVariant}"
                                           VerticalOptions="Center"
                                           HeightRequest="52"
                                           Margin="14,0,0,0"
                                           BackgroundColor="Transparent"
                                           ClearButtonVisibility="Never"
                                           ReturnType="Search">
                                        <Entry.Keyboard>
                                            <Keyboard x:FactoryMethod="Create">
                                                <x:Arguments>
                                                    <KeyboardFlags>Suggestions,CapitalizeNone</KeyboardFlags>
                                                </x:Arguments>
                                            </Keyboard>
                                        </Entry.Keyboard>
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup Name="CommonStates">
                                                <VisualState Name="Normal"/>
                                                <VisualState Name="Focused">
                                                    <VisualState.Setters>
                                                        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Entry>

                                    <!-- ③ Right icon column -->
                                    <Grid Grid.Column="2"
                                          VerticalOptions="Center"
                                          HorizontalOptions="Center"
                                          WidthRequest="48"
                                          HeightRequest="52">

                                        <!-- Search icon — visible when search box is empty -->
                                        <Border BackgroundColor="{StaticResource Primary}"
                                                StrokeShape="RoundRectangle 20"
                                                Stroke="Transparent"
                                                WidthRequest="40"
                                                HeightRequest="40"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding SearchText, Converter={StaticResource IsNullOrEmptyConverter}}">
                                            <Image Source="icon_search.png"
                                                   WidthRequest="18"
                                                   HeightRequest="18"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Clear icon — visible when search box has text -->
                                        <Border BackgroundColor="{StaticResource Primary}"
                                                StrokeShape="RoundRectangle 20"
                                                Stroke="Transparent"
                                                WidthRequest="40"
                                                HeightRequest="40"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding SearchText, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                                            <ImageButton Source="icon_clear.png"
                                                         BackgroundColor="Transparent"
                                                         Command="{Binding ClearSearchCommand}"
                                                         WidthRequest="18"
                                                         HeightRequest="18"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Padding="0"/>
                                        </Border>

                                    </Grid>
                                    <!-- ── end right icon ── -->

                                </Grid>
                            </Border>

                            <!-- ── END SEARCH BAR ── -->

                            <CollectionView ItemsSource="{Binding FilteredUsers}"
                                            SelectionMode="None">

                                <CollectionView.EmptyView>
                                    <VerticalStackLayout Spacing="16"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="Center"
                                                         Padding="40">
                                        <Label Text="📭"
                                               FontSize="72"
                                               HorizontalOptions="Center"
                                               TextColor="{StaticResource OutlineVariant}"/>
                                        <Label Text="No Users Yet"
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="18"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Get started by registering your first user"
                                               FontFamily="Inter"
                                               FontSize="13"
                                               TextColor="{StaticResource Outline}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"/>
                                        <Button Text="＋  Register First User"
                                                Command="{Binding AddUserCommand}"
                                                BackgroundColor="{StaticResource Primary}"
                                                TextColor="{StaticResource OnPrimary}"
                                                FontFamily="Inter"
                                                FontAttributes="Bold"
                                                CornerRadius="12"
                                                HeightRequest="48"
                                                HorizontalOptions="Center"
                                                Margin="0,8,0,0"/>
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                                </CollectionView.ItemsLayout>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:UserRegistration">
                                        <!-- User card — Shadow inlined; cannot use StaticResource style with Setter.Value in DataTemplate -->
                                        <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                                                StrokeShape="RoundRectangle 20"
                                                Stroke="#33C2C6D5"
                                                StrokeThickness="1"
                                                Padding="0"
                                                Margin="0,2">
                                            <Border.Shadow>
                                                <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05"/>
                                            </Border.Shadow>
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  Padding="14,14,10,14"
                                                  ColumnSpacing="14">

                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        StrokeShape="RoundRectangle 14"
                                                        Stroke="#1AC2C6D5"
                                                        StrokeThickness="1"
                                                        WidthRequest="56" HeightRequest="56"
                                                        VerticalOptions="Center"
                                                        Padding="0">
                                                    <Grid>
                                                        <Image Source="{Binding Photo1, Converter={StaticResource ByteArrayToImageConverter}}"
                                                               Aspect="AspectFill"
                                                               IsVisible="{Binding Photo1, Converter={StaticResource IsNotNullConverter}}"/>
                                                        <Border BackgroundColor="{StaticResource SurfaceContainerHighest}"
                                                                IsVisible="{Binding Photo1, Converter={StaticResource IsNullConverter}}">
                                                            <Label Text="👤"
                                                                   FontSize="28"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- User details -->
                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="4"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           FontFamily="Inter"
                                                           FontAttributes="Bold"
                                                           FontSize="15"
                                                           TextColor="{StaticResource Primary}"
                                                           LineBreakMode="TailTruncation"/>
                                                    <Label Text="{Binding UserId, StringFormat='ID: {0}'}"
                                                           FontFamily="Inter"
                                                           FontAttributes="Bold"
                                                           FontSize="10"
                                                           CharacterSpacing="1"
                                                           TextColor="{StaticResource OnSurfaceVariant}"/>
                                                    <Label Text="{Binding Age, StringFormat='Age: {0}'}"
                                                           FontFamily="Inter"
                                                           FontAttributes="Bold"
                                                           FontSize="10"
                                                           CharacterSpacing="1"
                                                           TextColor="{StaticResource OnSurfaceVariant}"/>
                                                    <Label Text="{Binding RegisteredDate, StringFormat='Enrolled: {0:MMM dd, yyyy}'}"
                                                           FontFamily="Inter"
                                                           FontAttributes="Bold"
                                                           FontSize="10"
                                                           CharacterSpacing="1"
                                                           TextColor="{StaticResource OnSurfaceVariant}"/>
                                                </VerticalStackLayout>

                                                <!-- Edit / Delete buttons -->
                                                <VerticalStackLayout Grid.Column="2"
                                                                     Spacing="4"
                                                                     VerticalOptions="Center">
                                                    <Border BackgroundColor="Transparent"
                                                            StrokeShape="RoundRectangle 8"
                                                            Stroke="Transparent"
                                                            WidthRequest="36" HeightRequest="36">
                                                        <ImageButton Source="icon_edit.png"
                                                                     BackgroundColor="Transparent"
                                                                     WidthRequest="20" HeightRequest="20"
                                                                     Command="{Binding BindingContext.EditUserCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                                     CommandParameter="{Binding .}"/>
                                                    </Border>
                                                    <Border BackgroundColor="Transparent"
                                                            StrokeShape="RoundRectangle 8"
                                                            Stroke="Transparent"
                                                            WidthRequest="36" HeightRequest="36">
                                                        <ImageButton Source="icon_delete.png"
                                                                     BackgroundColor="Transparent"
                                                                     WidthRequest="20" HeightRequest="20"
                                                                     Command="{Binding BindingContext.DeleteUserCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                                     CommandParameter="{Binding .}"/>
                                                    </Border>
                                                </VerticalStackLayout>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            </CollectionView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>

            <!-- Loading overlay -->
            <Border IsVisible="{Binding IsLoading}"
                    BackgroundColor="#CC000000"
                    StrokeShape="Rectangle"
                    Stroke="Transparent"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="16">
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       Color="White"
                                       WidthRequest="44" HeightRequest="44"/>
                    <Label Text="{Binding StatusMessage}"
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>

</ContentPage>
