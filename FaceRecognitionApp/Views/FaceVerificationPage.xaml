<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:camera="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.Camera"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.FaceVerificationPage"
             x:DataType="viewmodels:FaceVerificationViewModel"
             Title="Face Verification">

    <Grid RowDefinitions="*,Auto">

        <!-- ================= CAMERA AREA ================= -->

        <Grid Grid.Row="0">

            <!-- Camera Preview -->
            <camera:CameraView x:Name="cameraView"
                               IsVisible="{Binding IsCameraActive}"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill" />

            <!-- Camera Placeholder -->
            <Grid IsVisible="{Binding IsCameraActive, Converter={StaticResource InvertedBoolConverter}}"
                  BackgroundColor="Black">

                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="12">

                    <Label Text="📷"
                           FontSize="80"
                           HorizontalOptions="Center"
                           TextColor="Gray"/>

                    <Label Text="Camera Preview"
                           FontSize="20"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <Label Text="Press Start to begin verification"
                           FontSize="14"
                           TextColor="Gray"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </Grid>

            <!-- ================= CAMERA OVERLAY ================= -->

            <Grid IsVisible="{Binding IsCameraActive}"
                  Padding="16">

                <!-- Top Status -->
                <Border
                    VerticalOptions="Start"
                    HorizontalOptions="Fill"
                    BackgroundColor="#99000000"
                    Padding="12"
                    StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="10">

                        <BoxView WidthRequest="10"
                                 HeightRequest="10"
                                 CornerRadius="5"
                                 BackgroundColor="{Binding StatusColor}" />

                        <Label Text="{Binding RealtimeStatus}"
                               TextColor="White"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />

                    </HorizontalStackLayout>

                </Border>

                <!-- Face Detection Indicator -->
                <Border
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,60,0,0"
                    WidthRequest="70"
                    HeightRequest="70"
                    Stroke="White"
                    StrokeThickness="3"
                    StrokeShape="RoundRectangle 35"
                    BackgroundColor="{Binding StatusColor}"
                    IsVisible="{Binding FaceDetectedInFrame}">

                    <Label Text="{Binding IsVerified, Converter={StaticResource BoolToTextConverter}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="30"
                           TextColor="White"/>

                </Border>

                <!-- Confidence Panel -->
                <Border
                    VerticalOptions="End"
                    HorizontalOptions="Center"
                    Margin="0,0,0,80"
                    BackgroundColor="#CC000000"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    IsVisible="{Binding IsVerified}">

                    <VerticalStackLayout Spacing="6">

                        <Label Text="Confidence"
                               TextColor="Gray"
                               FontSize="12"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="{Binding Confidence, StringFormat='{0:F1}%'}"
                               TextColor="White"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>

                        <ProgressBar
                            Progress="{Binding Confidence, Converter={StaticResource PercentToDecimalConverter}}"
                            ProgressColor="{Binding StatusColor}"
                            WidthRequest="180"/>

                    </VerticalStackLayout>

                </Border>

                <!-- Verified User -->
                <Border
                    VerticalOptions="End"
                    HorizontalOptions="Center"
                    Margin="0,0,0,150"
                    BackgroundColor="#DD10B981"
                    Padding="14"
                    StrokeShape="RoundRectangle 12"
                    IsVisible="{Binding IsVerified}">

                    <HorizontalStackLayout Spacing="10">

                        <Label Text="✅"
                               FontSize="22"
                               VerticalOptions="Center"/>

                        <VerticalStackLayout>

                            <Label Text="{Binding MatchedUserName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label Text="{Binding MatchedUserId, StringFormat='ID: {0}'}"
                                   FontSize="12"
                                   TextColor="White"/>

                        </VerticalStackLayout>

                    </HorizontalStackLayout>

                </Border>

                <!-- Flip Camera Button -->
                <Button Text="🔄"
                        Command="{Binding ToggleCameraFacingCommand}"
                        WidthRequest="60"
                        HeightRequest="50"
                        CornerRadius="25"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        HorizontalOptions="End"
                        VerticalOptions="End"/>

            </Grid>

        </Grid>

        <!-- ================= CONTROL PANEL ================= -->

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Padding="16">

            <VerticalStackLayout Spacing="12">

                <!-- Camera Controls -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                    <Button
                        Grid.Column="0"
                        Text="▶ Start"
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding StartRealtimeCameraCommand}"
                        IsEnabled="{Binding IsCameraActive, Converter={StaticResource InvertedBoolConverter}}"/>

                    <Button
                        Grid.Column="1"
                        Text="⏹ Stop"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding StopRealtimeCameraCommand}"
                        IsEnabled="{Binding IsCameraActive}"/>

                </Grid>

                <!-- Status -->
                <Label
                    Text="{Binding StatusMessage}"
                    HorizontalTextAlignment="Center"
                    FontSize="13"
                    TextColor="{Binding StatusColor}"/>

                <!-- Reset -->
                <!--<Button
                    Text="Reset Verification"
                    Command="{Binding ResetCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>-->

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>