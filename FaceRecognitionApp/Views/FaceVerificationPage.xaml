<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.FaceVerificationPage"
             x:DataType="viewmodels:FaceVerificationViewModel"
             Title=""
             BackgroundColor="#F7F9FF"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    
    <ContentPage.Resources>

        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#2E6FD8"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="56"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#DEE3EB"/>
            <Setter Property="TextColor" Value="#171C22"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="56"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <Style x:Key="ResetPillButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#F0F4FC"/>
            <Setter Property="TextColor" Value="#2E6FD8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="48"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

    </ContentPage.Resources>

    <ScrollView BackgroundColor="#F7F9FF">
        <VerticalStackLayout Spacing="0">

            <Grid ColumnDefinitions="Auto,*"
                      BackgroundColor="#FFFFFF"
                      Padding="20,16"
                      ColumnSpacing="12">

                <Border Grid.Column="0"
                        BackgroundColor="#EFF6FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">

                    <Image Source="arrow_back.png"
                           HeightRequest="18"
                           WidthRequest="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">

                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                        </Image.GestureRecognizers>

                    </Image>

                </Border>

                <Label Grid.Column="1"
                           Text="AVIVANEXT"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#0056BB"
                           CharacterSpacing="2"
                           VerticalOptions="Center"/>
            </Grid>

            <VerticalStackLayout Padding="24,28,24,8"
                                 Spacing="6"
                                 HorizontalOptions="Center">
                <Label Text="Authenticating Identity"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#2E6FD8"
                       HorizontalOptions="Center"/>
                <Label Text="Verify identity using facial recognition"
                       FontSize="13"
                       TextColor="#424753"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Padding="20,16,20,32" Spacing="20">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="▶  Start"
                            Style="{StaticResource StartButton}"
                            Command="{Binding StartRealtimeCameraCommand}"
                            IsEnabled="{Binding IsCameraActive, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Button Grid.Column="1"
                            Text="■  Stop"
                            Style="{StaticResource StopButton}"
                            Command="{Binding StopRealtimeCameraCommand}"
                            IsEnabled="{Binding IsCameraActive}"/>
                </Grid>

                <Border BackgroundColor="#F0F4FC"
                        StrokeThickness="2"
                        Stroke="#C2C6D5"
                        StrokeShape="RoundRectangle 40"
                        HeightRequest="360"
                        HorizontalOptions="Fill">

                    <Grid>

                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="16"
                                             IsVisible="{Binding IsCameraActive, Converter={StaticResource InvertedBoolConverter}}">

                            <Border BackgroundColor="#DEE3EB"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 40"
                                    WidthRequest="80"
                                    HeightRequest="80"
                                    HorizontalOptions="Center">
                                <Image Source="icon_verify1.png"
                                       WidthRequest="24"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Label Text="Camera Preview"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#171C22"
                                   HorizontalOptions="Center"/>

                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding RealtimeStatus}"
                                       FontSize="14"
                                       TextColor="#424753"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="System will search registered users"
                                       FontSize="12"
                                       TextColor="#727784"
                                       FontAttributes="Italic"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="16"
                                             IsVisible="{Binding IsCameraActive}">

                            <ActivityIndicator IsRunning="{Binding IsCameraActive}"
                                               Color="#2E6FD8"
                                               WidthRequest="48"
                                               HeightRequest="48"
                                               HorizontalOptions="Center"/>

                            <Label Text="{Binding RealtimeStatus}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#2E6FD8"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>

                            <Label Text="{Binding LivenessStatus}"
                                   FontSize="12"
                                   TextColor="#424753"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding LivenessStatus, Converter={StaticResource IsNotNullConverter}}"/>

                            <Label Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   TextColor="#727784"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                        <AbsoluteLayout IsVisible="{Binding IsCameraActive}">
                            <BoxView Color="#2E6FD8" WidthRequest="32" HeightRequest="3"
                                     AbsoluteLayout.LayoutBounds="16,16,32,3"/>
                            <BoxView Color="#2E6FD8" WidthRequest="3" HeightRequest="32"
                                     AbsoluteLayout.LayoutBounds="16,16,3,32"/>
                            <BoxView Color="#2E6FD8" WidthRequest="32" HeightRequest="3"
                                     AbsoluteLayout.LayoutBounds="1,16,32,3"
                                     AbsoluteLayout.LayoutFlags="XProportional"/>
                            <BoxView Color="#2E6FD8" WidthRequest="3" HeightRequest="32"
                                     AbsoluteLayout.LayoutBounds="1,16,3,32"
                                     AbsoluteLayout.LayoutFlags="XProportional"/>
                            <BoxView Color="#2E6FD8" WidthRequest="32" HeightRequest="3"
                                     AbsoluteLayout.LayoutBounds="16,1,32,3"
                                     AbsoluteLayout.LayoutFlags="YProportional"/>
                            <BoxView Color="#2E6FD8" WidthRequest="3" HeightRequest="32"
                                     AbsoluteLayout.LayoutBounds="16,1,3,32"
                                     AbsoluteLayout.LayoutFlags="YProportional"/>
                            <BoxView Color="#2E6FD8" WidthRequest="32" HeightRequest="3"
                                     AbsoluteLayout.LayoutBounds="1,1,32,3"
                                     AbsoluteLayout.LayoutFlags="XProportional,YProportional"/>
                            <BoxView Color="#2E6FD8" WidthRequest="3" HeightRequest="32"
                                     AbsoluteLayout.LayoutBounds="1,1,3,32"
                                     AbsoluteLayout.LayoutFlags="XProportional,YProportional"/>
                        </AbsoluteLayout>

                    </Grid>
                </Border>

                <!-- ── VERIFIED SUCCESS CARD ── -->
                <!-- Appears after successful match — matches success-container colour -->
                <Border BackgroundColor="#E8F5E9"
                        Stroke="#A5D6A7"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="20"
                        IsVisible="{Binding IsVerified}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="✅ Identity Verified"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#2E7D32"
                               HorizontalOptions="Center"/>

                        <BoxView HeightRequest="1" Color="#A5D6A7"/>

                        <!-- Name + User ID -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Name"
                                   FontSize="12"
                                   TextColor="#424753"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding MatchedUserName}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#171C22"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="User ID"
                                   FontSize="12"
                                   TextColor="#424753"
                                   VerticalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding MatchedUserId}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#171C22"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Confidence bar -->
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Confidence"
                                       FontSize="12"
                                       TextColor="#424753"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Confidence, StringFormat='{0:F1}%'}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32"/>
                            </Grid>
                            <ProgressBar Progress="{Binding Confidence, Converter={StaticResource PercentToDecimalConverter}}"
                                         ProgressColor="#2E7D32"
                                         BackgroundColor="#A5D6A7"
                                         HeightRequest="8"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── NOT VERIFIED CARD ── -->
                <!-- Appears when face is not recognized -->
                <Border BackgroundColor="#FFF0F0"
                        Stroke="#FFCDD2"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="20"
                        IsVisible="{Binding IsVerified, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding FaceDetectedInFrame}">
                        <Label Text="❌ Not Recognized"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#BA1A1A"
                               HorizontalOptions="Center"/>
                        <Label Text="Face not found in the registered database"
                               FontSize="13"
                               TextColor="#424753"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ── RESET BUTTON ── -->
                <Button Text=" Reset Verification"
                        Style="{StaticResource ResetPillButton}"
                        Command="{Binding ResetCommand}"
                        HorizontalOptions="Fill"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
