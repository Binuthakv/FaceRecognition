<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.AdminLoginPage"
             x:DataType="viewmodels:AdminLoginViewModel"
             Title="Admin Login"
             BackgroundColor="{StaticResource Surface}"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*,Auto"
          BackgroundColor="{StaticResource Surface}">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ── TOP APP BAR ── -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                        StrokeShape="Rectangle"
                        Stroke="Transparent"
                        Padding="16,12">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
                    </Border.Shadow>
                    <Label Text="AVIVANEXT"
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="16"
                           CharacterSpacing="2"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                </Border>

                <!-- ── PAGE HEADING ── -->
                <VerticalStackLayout Padding="24,65,24,4" Spacing="4" HorizontalOptions="Center">
                    <Label Text="Admin Login"
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="22"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Only authorized administrators can access this system"
                           FontFamily="Inter"
                           FontSize="13"
                           TextColor="{StaticResource OnSurfaceVariant}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- ── LOGIN FORM CARD ── -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 40"
                        Stroke="Transparent"
                        Margin="12,16,12,24"
                        Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="#0056BB" Offset="0,20" Radius="40" Opacity="0.06"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="28">

                        <VerticalStackLayout Spacing="14">

                            <!-- Username -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="USERNAME OR EMAIL"
                                       FontFamily="Monospace"
                                       FontSize="10"
                                       CharacterSpacing="3"
                                       TextColor="{StaticResource Outline}"
                                       Margin="4,0"/>
                                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="Transparent"
                                        StrokeThickness="0"
                                        MinimumHeightRequest="56"
                                        Padding="4,0">
                                    <Entry Placeholder="Enter username or email"
                                           Text="{Binding Username}"
                                           FontSize="15"
                                           FontFamily="Inter"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource OutlineVariant}"
                                           BackgroundColor="Transparent"
                                           MinimumHeightRequest="56"
                                           Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="PASSWORD"
                                       FontFamily="Monospace"
                                       FontSize="10"
                                       CharacterSpacing="3"
                                       TextColor="{StaticResource Outline}"
                                       Margin="4,0"/>
                                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="Transparent"
                                        StrokeThickness="0"
                                        MinimumHeightRequest="56"
                                        Padding="4,0">
                                    <Entry Placeholder="Enter password"
                                           Text="{Binding Password}"
                                           IsPassword="True"
                                           FontSize="15"
                                           FontFamily="Inter"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource OutlineVariant}"
                                           BackgroundColor="Transparent"
                                           MinimumHeightRequest="56"
                                           Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Remember Me -->
                            <HorizontalStackLayout Spacing="8"
                                                   VerticalOptions="Center"
                                                   Margin="4,4,0,0">
                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRememberMeCommand}"/>
                                </HorizontalStackLayout.GestureRecognizers>

                                <!-- Custom checkbox: no built-in padding unlike native CheckBox -->
                                <Border WidthRequest="20"
                                        HeightRequest="20"
                                        StrokeThickness="1.5"
                                        Stroke="{StaticResource Primary}"
                                        StrokeShape="RoundRectangle 4"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding RememberMe}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="✓"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource OnPrimary}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding RememberMe}"/>
                                </Border>

                                <Label Text="Remember me for 30 days"
                                       FontSize="13"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}"/>

                        <!-- Error banner -->
                        <Border BackgroundColor="#FEF2F2"
                                Stroke="#FECACA"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="16,12"
                                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding ErrorMessage}"
                                       FontSize="13"
                                       TextColor="#991B1B"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Success banner -->
                        <Border BackgroundColor="#F0FFF4"
                                Stroke="#BBF7D0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="16,12"
                                IsVisible="{Binding SuccessMessage, Converter={StaticResource IsNotNullConverter}}">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="✅" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding SuccessMessage}"
                                       FontSize="13"
                                       TextColor="#166534"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Login button + spinner -->
                        <VerticalStackLayout Spacing="12">
                            <Button Text="Login"
                                    TextColor="{StaticResource OnPrimary}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    HeightRequest="64"
                                    CornerRadius="32"
                                    Command="{Binding LoginCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource PrimaryContainer}" Offset="0.0"/>
                                        <GradientStop Color="{StaticResource Primary}"          Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Shadow>
                                    <Shadow Brush="#0056BB" Offset="0,10" Radius="30" Opacity="0.30"/>
                                </Button.Shadow>
                            </Button>

                            <ActivityIndicator IsRunning="{Binding IsLoading}"
                                               IsVisible="{Binding IsLoading}"
                                               Color="{StaticResource Primary}"
                                               HeightRequest="28"
                                               WidthRequest="28"
                                               HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Info tile -->
                        <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                Padding="14,12">
                            <Label Text="ℹ️  Ensure you are on a secure and trusted network before logging in"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── FOOTER ── -->
        <Label Grid.Row="1"
               Text="© AVIVANEXT  •  Authorized personnel only"
               FontSize="11"
               TextColor="{StaticResource Outline}"
               CharacterSpacing="1"
               HorizontalTextAlignment="Center"
               Padding="24,12"
               BackgroundColor="{StaticResource Surface}"/>

    </Grid>

</ContentPage>
