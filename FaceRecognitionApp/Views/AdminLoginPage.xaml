<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.AdminLoginPage"
             x:DataType="viewmodels:AdminLoginViewModel"
             Title="Admin Login"
             BackgroundColor="#F7F9FF"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" Padding="0">
        
        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,60,24,24" Spacing="0" VerticalOptions="Start">
                
                <!-- Header -->
                <VerticalStackLayout Spacing="12" Margin="0,0,0,48">
                    <Label Text="AVIVANEXT"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#0056BB"
                           CharacterSpacing="2"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Admin Login"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#171C22"
                           HorizontalTextAlignment="Center"/>                    
                </VerticalStackLayout>

                <!-- Login Form -->
                <VerticalStackLayout Spacing="16" Margin="0,0,0,24">
                    
                    <!-- Username/Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="USERNAME OR EMAIL"
                               FontSize="12"
                               TextColor="#727784"
                               FontAttributes="Bold"
                               CharacterSpacing="1"/>
                        <Border BackgroundColor="#EDEFF5"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="16,0"
                                HeightRequest="56">
                            <Entry Placeholder="Enter username or email"
                                   Text="{Binding Username}"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   TextColor="#171C22"
                                   PlaceholderColor="#C2C6D5"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="PASSWORD"
                               FontSize="12"
                               TextColor="#727784"
                               FontAttributes="Bold"
                               CharacterSpacing="1"/>
                        <Border BackgroundColor="#EDEFF5"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="16,0"
                                HeightRequest="56">
                            <Entry Placeholder="Enter password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   TextColor="#171C22"
                                   PlaceholderColor="#C2C6D5"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Remember Me -->
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <CheckBox IsChecked="{Binding RememberMe}"
                                  Color="#0056BB"
                                  VerticalOptions="Center"/>
                        <Label Text="Remember me for 30 days"
                               FontSize="13"
                               TextColor="#424753"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>

                <!-- Error Message -->
                <Border BackgroundColor="#FEF2F2"
                        Stroke="#FECACA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,8"
                        Margin="0,0,0,16"
                        IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="{Binding ErrorMessage}"
                           FontSize="12"
                           TextColor="#991B1B"/>
                </Border>

                <!-- Success Message -->
                <Border BackgroundColor="#F0FFF4"
                        Stroke="#BBF7D0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,8"
                        Margin="0,0,0,16"
                        IsVisible="{Binding SuccessMessage, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="{Binding SuccessMessage}"
                           FontSize="12"
                           TextColor="#166534"/>
                </Border>

                <!-- Login Button -->
                <Button Text="Login"
                        TextColor="#FFFFFF"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="12"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                        Margin="0,0,0,12">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2E6FD8" Offset="0.0"/>
                            <GradientStop Color="#0056BB" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#0056BB"
                                   HeightRequest="32"
                                   WidthRequest="32"
                                   HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <Label Grid.Row="1"
               Text="Only authorized administrators can access this system"
               FontSize="11"
               TextColor="#727784"
               HorizontalTextAlignment="Center"
               Padding="24,16"
               LineBreakMode="WordWrap"/>

    </Grid>

</ContentPage>
