<?xml version="1.0" encoding="utf-8" ?>
<!--
    AdminLoginPage.xaml
    All color tokens and style definitions removed — resolved from AppStyles.xaml.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.AdminLoginPage"
             x:DataType="viewmodels:AdminLoginViewModel"
             Title="Admin Login"
             BackgroundColor="{StaticResource Surface}"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*,Auto"
          BackgroundColor="{StaticResource Surface}">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ── TOP APP BAR ── -->
                <Border Style="{StaticResource TopAppBarStyle}">
                    <Label Text="AVIVANEXT"
                           Style="{StaticResource BrandWordmarkStyle}"
                           Margin="0"/>
                </Border>

                <!-- ── PAGE HEADING ── -->
                <VerticalStackLayout Padding="24,65,24,4" Spacing="4" HorizontalOptions="Center">
                    <Label Text="Admin Login"
                           Style="{StaticResource PageTitleStyle}"
                           FontSize="22"/>
                    <Label Text="Only authorized administrators can access this system"
                           Style="{StaticResource PageSubtitleStyle}"/>
                </VerticalStackLayout>

                <!-- ── LOGIN FORM CARD ── -->
                <Border Style="{StaticResource MainCardStyle}"
                        StrokeShape="RoundRectangle 40"
                        Margin="12,16,12,24"
                        Padding="24,28">

                    <VerticalStackLayout Spacing="28">

                        <!-- Fields -->
                        <VerticalStackLayout Spacing="14">

                            <!-- Username -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="USERNAME OR EMAIL"
                                       Style="{StaticResource OverlineLabelStyle}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource FormEntryStyle}"
                                           Placeholder="Enter username or email"
                                           Text="{Binding Username}"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="PASSWORD"
                                       Style="{StaticResource OverlineLabelStyle}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource FormEntryStyle}"
                                           Placeholder="Enter password"
                                           Text="{Binding Password}"
                                           IsPassword="True"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Remember Me -->
                            <HorizontalStackLayout Spacing="10"
                                                   VerticalOptions="Center"
                                                   Margin="4,4,0,0">
                                <CheckBox IsChecked="{Binding RememberMe}"
                                          Color="{StaticResource Primary}"
                                          VerticalOptions="Center"/>
                                <Label Text="Remember me for 30 days"
                                       FontSize="13"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource SurfaceVariant}"/>

                        <!-- Error banner -->
                        <Border Style="{StaticResource ErrorBannerStyle}"
                                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding ErrorMessage}"
                                       FontSize="13"
                                       TextColor="{StaticResource ErrorBannerText}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Success banner -->
                        <Border Style="{StaticResource SuccessBannerStyle}"
                                IsVisible="{Binding SuccessMessage, Converter={StaticResource IsNotNullConverter}}">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="✅" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding SuccessMessage}"
                                       FontSize="13"
                                       TextColor="{StaticResource SuccessBannerText}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Login button + spinner -->
                        <VerticalStackLayout Spacing="12">
                            <Button Text="Login"
                                    Style="{StaticResource LoginButtonStyle}"
                                    Command="{Binding LoginCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource PrimaryContainer}" Offset="0.0"/>
                                        <GradientStop Color="{StaticResource Primary}"          Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <ActivityIndicator IsRunning="{Binding IsLoading}"
                                               IsVisible="{Binding IsLoading}"
                                               Color="{StaticResource Primary}"
                                               HeightRequest="28"
                                               WidthRequest="28"
                                               HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Info footer -->
                        <Border Style="{StaticResource InfoTileStyle}">
                            <Label Text="ℹ️  Ensure you are on a secure and trusted network before logging in"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── FOOTER ── -->
        <Label Grid.Row="1"
               Text="© AVIVANEXT  •  Authorized personnel only"
               FontSize="11"
               TextColor="{StaticResource Outline}"
               CharacterSpacing="1"
               HorizontalTextAlignment="Center"
               Padding="24,12"
               BackgroundColor="{StaticResource Surface}"/>

    </Grid>

</ContentPage>
