<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:camera="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.Camera"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.UserRegistrationPage"
             x:DataType="viewmodels:UserRegistrationViewModel"
             Title="Register User"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>
        <Style x:Key="FormEntryStyle" TargetType="Entry">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="MinimumHeightRequest" Value="44"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Focused"/>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="TextColor"
                                        Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid>

        <!-- ① Scrollable form content -->
        <ScrollView IsVisible="{Binding IsCameraPreviewVisible, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- User ID -->
                <Border StrokeShape="RoundRectangle 8" Stroke="#E0E0E0" StrokeThickness="1">
                    <Entry x:Name="userIdEntry"
                           Style="{StaticResource FormEntryStyle}"
                           Text="{Binding UserId}"
                           IsReadOnly="{Binding IsUserIdReadOnly}"
                           Placeholder="User ID"
                           Margin="8,0" />
                </Border>

                <!-- Full Name -->
                <Border StrokeShape="RoundRectangle 8" Stroke="#E0E0E0" StrokeThickness="1">
                    <Entry Style="{StaticResource FormEntryStyle}"
                           Text="{Binding Name}"
                           Placeholder="Full Name"
                           Margin="8,0" />
                </Border>

                <!-- Date of Birth -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Date of Birth *"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="{StaticResource Primary}"/>
                    <Border Style="{StaticResource InputContainer}">
                        <DatePicker Date="{Binding DateOfBirth}"
                                    MinimumDate="01/01/1900"
                                    FontSize="16"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Photo Section Header — standalone, no large wrapping card -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,8,0,0">
                    <Label Text="📸" FontSize="32" VerticalOptions="Center"/>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Face Recognition Photos"
                               Style="{StaticResource SectionTitle}"
                               Margin="0"/>
                        <Border Style="{StaticResource Badge}">
                            <Label Text="{Binding PhotoCount, StringFormat='{0}/3 photos captured'}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource White}"/>
                        </Border>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Photo 1 - Front Face -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 12"
                        Shadow="{x:Null}"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="1️⃣" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="Front Face" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Secondary}"
                                IsVisible="{Binding Photo1, Converter={StaticResource IsNotNullConverter}}">
                            <Image Source="{Binding Photo1}" Aspect="AspectFill">
                                <Image.Rotation>
                                    <OnPlatform x:TypeArguments="x:Double">
                                        <On Platform="iOS" Value="0"/>
                                        <On Platform="Android" Value="0"/>
                                        <On Platform="WinUI" Value="0"/>
                                    </OnPlatform>
                                </Image.Rotation>
                            </Image>
                        </Border>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Gray300}"
                                IsVisible="{Binding Photo1, Converter={StaticResource IsNullConverter}}">
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                                <Label Text="📷" FontSize="56" HorizontalOptions="Center" TextColor="{StaticResource Gray400}"/>
                                <Label Text="No photo captured" Style="{StaticResource Caption}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0" Text="📷 Capture"
                                    Command="{Binding StartCapturePhoto1Command}"
                                    Style="{StaticResource IconButton}"/>
                            <Button Grid.Column="1" Text="🖼️ Pick"
                                    Command="{Binding PickPhoto1Command}"
                                    Style="{StaticResource IconButton}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Photo 2 - Left Profile -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 12"
                        Shadow="{x:Null}"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="2️⃣" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="Left Profile" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Secondary}"
                                IsVisible="{Binding Photo2, Converter={StaticResource IsNotNullConverter}}">
                            <Image Source="{Binding Photo2}" Aspect="AspectFill">
                                <Image.Rotation>
                                    <OnPlatform x:TypeArguments="x:Double">
                                        <On Platform="iOS" Value="0"/>
                                        <On Platform="Android" Value="0"/>
                                        <On Platform="WinUI" Value="0"/>
                                    </OnPlatform>
                                </Image.Rotation>
                            </Image>
                        </Border>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Gray300}"
                                IsVisible="{Binding Photo2, Converter={StaticResource IsNullConverter}}">
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                                <Label Text="📷" FontSize="56" HorizontalOptions="Center" TextColor="{StaticResource Gray400}"/>
                                <Label Text="No photo captured" Style="{StaticResource Caption}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0" Text="📷 Capture"
                                    Command="{Binding StartCapturePhoto2Command}"
                                    Style="{StaticResource IconButton}"/>
                            <Button Grid.Column="1" Text="🖼️ Pick"
                                    Command="{Binding PickPhoto2Command}"
                                    Style="{StaticResource IconButton}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Photo 3 - Right Profile -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 12"
                        Shadow="{x:Null}"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="3️⃣" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="Right Profile" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Secondary}"
                                IsVisible="{Binding Photo3, Converter={StaticResource IsNotNullConverter}}">
                            <Image Source="{Binding Photo3}" Aspect="AspectFill">
                                <Image.Rotation>
                                    <OnPlatform x:TypeArguments="x:Double">
                                        <On Platform="iOS" Value="0"/>
                                        <On Platform="Android" Value="0"/>
                                        <On Platform="WinUI" Value="0"/>
                                    </OnPlatform>
                                </Image.Rotation>
                            </Image>
                        </Border>
                        <Border Style="{StaticResource PhotoFrame}"
                                Stroke="{StaticResource Gray300}"
                                IsVisible="{Binding Photo3, Converter={StaticResource IsNullConverter}}">
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                                <Label Text="📷" FontSize="56" HorizontalOptions="Center" TextColor="{StaticResource Gray400}"/>
                                <Label Text="No photo captured" Style="{StaticResource Caption}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0" Text="📷 Capture"
                                    Command="{Binding StartCapturePhoto3Command}"
                                    Style="{StaticResource IconButton}"/>
                            <Button Grid.Column="1" Text="🖼️ Pick"
                                    Command="{Binding PickPhoto3Command}"
                                    Style="{StaticResource IconButton}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Status Card -->
                <Border Style="{StaticResource StatusCard}"
                        Shadow="{x:Null}"
                        Stroke="{Binding StatusColor}"
                        BackgroundColor="{Binding StatusColor, Converter={StaticResource ColorToLightColorConverter}}"
                        IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}">
                    <VerticalStackLayout Spacing="12">
                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           Color="{Binding StatusColor}"
                                           HeightRequest="32"
                                           WidthRequest="32"
                                           HorizontalOptions="Center"/>
                        <Label Text="{Binding StatusMessage}"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               TextColor="{Binding StatusColor}"
                               FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,8,0,20">
                    <Button Grid.Column="0"
                            Text="{Binding IsEditMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='💾 Update User|✅ Register User'}"
                            Command="{Binding RegisterUserCommand}"
                            Style="{StaticResource SuccessButton}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Button Grid.Column="1"
                            Text="{Binding IsEditMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='❌ Cancel|🔄 Reset'}"
                            Command="{Binding ResetFormCommand}"
                            Style="{StaticResource ResetButton}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <!-- Info Footer -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLighter}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Shadow="{x:Null}"
                        Padding="16">
                    <Label Text="ℹ️ All fields and 3 photos are required for successful face recognition"
                           Style="{StaticResource Caption}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ② Camera preview overlay -->
        <Grid IsVisible="{Binding IsCameraPreviewVisible}"
              BackgroundColor="Black">

            <camera:CameraView x:Name="cameraView"
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"  
                               WidthRequest="400"
                               HeightRequest="600"/>

            <!-- Top info bar -->
            <Border BackgroundColor="#CC000000"
                    VerticalOptions="Start"
                    Padding="20,48,20,16">
                <Grid ColumnDefinitions="48,*,48">
                    <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding ActivePhotoSlot, StringFormat='📸 Photo {0}'}"
                               TextColor="White"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Center your face in the frame"
                               TextColor="#CCFFFFFF"
                               FontSize="14"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Button x:Name="flipCameraButton"
                            Grid.Column="2"
                            Text="🔄"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="22"
                            WidthRequest="48"
                            HeightRequest="48"
                            Padding="0"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Clicked="OnFlipCameraClicked"/>
                </Grid>
            </Border>

            <VerticalStackLayout VerticalOptions="End"
                                 Padding="24,0,24,52"
                                 Spacing="20"
                                 BackgroundColor="#CC000000">
                <Border StrokeShape="Ellipse"
                        Stroke="White"
                        StrokeThickness="3"
                        BackgroundColor="Transparent"
                        WidthRequest="88"
                        HeightRequest="88"
                        HorizontalOptions="Center">
                    <Button x:Name="shutterButton"
                            BackgroundColor="White"
                            CornerRadius="36"
                            WidthRequest="72"
                            HeightRequest="72"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Clicked="OnCaptureClicked"/>
                </Border>
                <Button Text="✕  Cancel"
                        Command="{Binding CancelCameraPreviewCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        BorderColor="Transparent"
                        FontSize="16"
                        HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
