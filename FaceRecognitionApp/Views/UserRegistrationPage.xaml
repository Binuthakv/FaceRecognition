<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:camera="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui.Camera"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.UserRegistrationPage"
             x:DataType="viewmodels:UserRegistrationViewModel"
             Title="Register User"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>

        <!-- COLOR PALETTE -->
        <Color x:Key="Primary">#0056BB</Color>
        <Color x:Key="PrimaryContainer">#2E6FD8</Color>
        <Color x:Key="OnPrimary">#FFFFFF</Color>
        <Color x:Key="Surface">#F7F9FF</Color>
        <Color x:Key="SurfaceContainerLow">#F0F4FC</Color>
        <Color x:Key="SurfaceContainerLowest">#FFFFFF</Color>
        <Color x:Key="SurfaceContainer">#EAEEF6</Color>
        <Color x:Key="SurfaceVariant">#DEE3EB</Color>
        <Color x:Key="OnSurface">#171C22</Color>
        <Color x:Key="OnSurfaceVariant">#424753</Color>
        <Color x:Key="Outline">#727784</Color>
        <Color x:Key="OutlineVariant">#C2C6D5</Color>
        <Color x:Key="ErrorColor">#BA1A1A</Color>
        <Color x:Key="SuccessGreen">#16A34A</Color>
        <Color x:Key="SuccessGreenBg">#F0FDF4</Color>
        <Color x:Key="SuccessGreenBorder">#BBF7D0</Color>

        <!-- ENTRY STYLE  -->
        <Style x:Key="FormEntryStyle" TargetType="Entry">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="TextColor" Value="{StaticResource OnSurface}"/>
            <Setter Property="PlaceholderColor" Value="{StaticResource OutlineVariant}"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="MinimumHeightRequest" Value="56"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Focused"/>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{StaticResource OnSurface}"/>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <!-- Field container border -->
        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLow}"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>

        <!-- Section overline label -->
        <Style x:Key="OverlineLabel" TargetType="Label">
            <Setter Property="FontFamily" Value="Monospace"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="CharacterSpacing" Value="3"/>
            <Setter Property="TextColor" Value="{StaticResource Outline}"/>
            <Setter Property="FontAttributes" Value="None"/>
        </Style>

        <!-- Photo slot wrapper card -->
        <Style x:Key="PhotoCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLowest}"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
            <Setter Property="Stroke" Value="{StaticResource SurfaceVariant}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="#0A0056BB" Offset="0,4" Radius="16" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Photo slot label — tiny monospace uppercase -->
        <Style x:Key="SlotLabel" TargetType="Label">
            <Setter Property="FontFamily" Value="Monospace"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="CharacterSpacing" Value="3"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        </Style>

        <!-- CAPTURE primary button -->
        <Style x:Key="CaptureBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
            <Setter Property="TextColor" Value="{StaticResource OnPrimary}"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CharacterSpacing" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- SELECT outline button -->
        <Style x:Key="SelectBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLowest}"/>
            <Setter Property="TextColor" Value="{StaticResource OnSurface}"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CharacterSpacing" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="BorderColor" Value="{StaticResource OutlineVariant}"/>
            <Setter Property="BorderWidth" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

    </ContentPage.Resources>

    <Grid>

        <Grid RowDefinitions="Auto,*"
              IsVisible="{Binding IsCameraPreviewVisible, Converter={StaticResource InvertedBoolConverter}}">

            <!-- ── TOP APP BAR ── -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource SurfaceContainerLowest}"
                    StrokeShape="Rectangle"
                    Stroke="Transparent"
                    Padding="16,12">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*">
                    <!-- Back button -->
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="Start"
                            VerticalOptions="Center">
                        <Image Source="arrow_back.png"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">

                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Image.GestureRecognizers>

                        </Image>
                    </Border>
                    <!-- Brand wordmark -->
                    <Label Grid.Column="1"
                           Text="AVIVANEXT"
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="16"
                           CharacterSpacing="2"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"
                           Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- ── SCROLLABLE BODY ── -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,16,16,32" Spacing="0">

                    <!-- Page heading -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,8,0,20">
                        <Label Text="Register User"
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="20"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"/>
                        <Label Text="Enter details for multi-angle biometric enrollment"
                               FontFamily="Inter"
                               FontSize="13"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 32"
                            Stroke="Transparent"
                            Padding="20,24">
                        <Border.Shadow>
                            <Shadow Brush="#0056BB" Offset="0,20" Radius="40" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="28">

                            <!-- ── IDENTIFICATION ENTRY SECTION ── -->
                            <VerticalStackLayout Spacing="12">
                                <Label Text="IDENTIFICATION ENTRY"
                                       Style="{StaticResource OverlineLabel}"
                                       Margin="4,0"/>

                                <!-- Employee ID -->
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry x:Name="userIdEntry"
                                           Style="{StaticResource FormEntryStyle}"
                                           Text="{Binding UserId}"
                                           IsReadOnly="{Binding IsUserIdReadOnly}"
                                           Placeholder="User ID"
                                           Margin="12,0"/>
                                </Border>

                                <!-- Full Name -->
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Style="{StaticResource FormEntryStyle}"
                                           Text="{Binding Name}"
                                           Placeholder="Full Name"
                                           Margin="12,0"/>
                                </Border>

                                <!-- Date of Birth -->
                                <Border Style="{StaticResource FieldBorder}">
                                    <DatePicker Date="{Binding DateOfBirth}"
                                                MinimumDate="01/01/1900"
                                                FontSize="15"
                                                TextColor="{StaticResource OnSurface}"
                                                BackgroundColor="Transparent"
                                                MinimumHeightRequest="56"
                                                Margin="12,0"/>
                                </Border>

                                <!-- Sex / Gender -->
                                <Border Style="{StaticResource FieldBorder}">
                                    <Picker ItemsSource="{Binding SexOptions}"
                                            SelectedItem="{Binding Sex}"
                                            Title="Select Sex"
                                            FontSize="15"
                                            TextColor="{StaticResource OnSurface}"
                                            TitleColor="{StaticResource OutlineVariant}"
                                            BackgroundColor="Transparent"
                                            MinimumHeightRequest="56"
                                            Margin="12,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- ── BIOMETRIC CAPTURE SECTION ── -->
                            <VerticalStackLayout Spacing="20">

                                <!-- Section header with divider -->
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="MULTI-ANGLE BIOMETRIC CAPTURE"
                                           Style="{StaticResource OverlineLabel}"
                                           Margin="4,0"/>
                                    <!-- Photo count badge -->
                                    <Border Grid.Row="0" Grid.Column="1"
                                            BackgroundColor="{StaticResource PrimaryContainer}"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="Transparent"
                                            Padding="10,4">
                                        <Label Text="{Binding PhotoCount, StringFormat='{0}/3'}"
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="11"
                                               TextColor="{StaticResource OnPrimary}"/>
                                    </Border>
                                    <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                             HeightRequest="1"
                                             Color="{StaticResource SurfaceVariant}"
                                             Margin="0,8,0,0"/>
                                </Grid>

                                <!-- ── PHOTO 1: FRONT FACE ── -->
                                <Border Style="{StaticResource PhotoCard}">
                                    <VerticalStackLayout Spacing="0">
                                        <!-- Card header -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              Padding="16,14,16,10">
                                            <Label Grid.Column="0"
                                                   Text="1. FRONT FACE"
                                                   Style="{StaticResource SlotLabel}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="REQUIRED"
                                                   FontFamily="Monospace"
                                                   FontSize="9"
                                                   CharacterSpacing="2"
                                                   TextColor="{StaticResource Outline}"
                                                   VerticalOptions="Center"/>
                                        </Grid>

                                        <!-- Photo frame with corner guides -->
                                        <Grid HeightRequest="200" Margin="12,0">
                                            <!-- Placeholder when no photo -->
                                            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource SurfaceVariant}"
                                                    IsVisible="{Binding Photo1, Converter={StaticResource IsNullConverter}}">
                                                <VerticalStackLayout VerticalOptions="Center"
                                                                     HorizontalOptions="Center"
                                                                     Spacing="8">
                                                    <Image Source="icon_person.png"
                                                           HeightRequest="52"
                                                           WidthRequest="52"
                                                           HorizontalOptions="Center"/>
                                                    <Label Text="No photo captured"
                                                           FontFamily="Inter"
                                                           FontSize="12"
                                                           TextColor="{StaticResource Outline}"
                                                           HorizontalOptions="Center"/>
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Captured photo -->
                                            <Border BackgroundColor="Black"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource PrimaryContainer}"
                                                    StrokeThickness="2"
                                                    IsVisible="{Binding Photo1, Converter={StaticResource IsNotNullConverter}}">
                                                <Image Source="{Binding Photo1}"
                                                       Aspect="AspectFill">
                                                    <Image.Rotation>
                                                        <OnPlatform x:TypeArguments="x:Double">
                                                            <On Platform="iOS" Value="0"/>
                                                            <On Platform="Android" Value="0"/>
                                                            <On Platform="WinUI" Value="0"/>
                                                        </OnPlatform>
                                                    </Image.Rotation>
                                                </Image>
                                            </Border>

                                            <!-- Corner guide overlay (primary-colored brackets) -->
                                            <Grid IsVisible="{Binding Photo1, Converter={StaticResource IsNullConverter}}"
                                                  InputTransparent="True"
                                                  Margin="8">
                                                <!-- top-left corner -->
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="Start" Margin="0,0,0,0"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="Start" Margin="0,0,0,0"/>
                                                <!-- top-right corner -->
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="Start" Margin="0,0,0,0"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="Start" Margin="0,0,0,0"/>
                                                <!-- bottom-left corner -->
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="End" Margin="0,0,0,0"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="End" Margin="0,0,0,0"/>
                                                <!-- bottom-right corner -->
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="End" Margin="0,0,0,0"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="End" Margin="0,0,0,0"/>
                                            </Grid>
                                        </Grid>

                                        <!-- Action buttons -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="12,10,12,14">
                                            <!-- Capture -->
                                            <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                            <!-- Select -->
                                            <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- ── PHOTO 2: LEFT PROFILE ── -->
                                <Border Style="{StaticResource PhotoCard}">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Padding="16,14,16,10">
                                            <Label Grid.Column="0"
                                                   Text="2. LEFT PROFILE"
                                                   Style="{StaticResource SlotLabel}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="REQUIRED"
                                                   FontFamily="Monospace"
                                                   FontSize="9"
                                                   CharacterSpacing="2"
                                                   TextColor="{StaticResource Outline}"
                                                   VerticalOptions="Center"/>
                                        </Grid>

                                        <Grid HeightRequest="200" Margin="12,0">
                                            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource SurfaceVariant}"
                                                    IsVisible="{Binding Photo2, Converter={StaticResource IsNullConverter}}">
                                                <VerticalStackLayout VerticalOptions="Center"
                                                                     HorizontalOptions="Center"
                                                                     Spacing="8">
                                                    <Image Source="icon_person_profile_left.png"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               HorizontalOptions="Center"/>

                                                    <Label Text="No photo captured"
                                                           FontFamily="Inter"
                                                           FontSize="12"
                                                           TextColor="{StaticResource Outline}"
                                                           HorizontalOptions="Center"/>
                                                </VerticalStackLayout>
                                            </Border>
                                            <Border BackgroundColor="Black"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource PrimaryContainer}"
                                                    StrokeThickness="2"
                                                    IsVisible="{Binding Photo2, Converter={StaticResource IsNotNullConverter}}">
                                                <Image Source="{Binding Photo2}"
                                                       Aspect="AspectFill">
                                                    <Image.Rotation>
                                                        <OnPlatform x:TypeArguments="x:Double">
                                                            <On Platform="iOS" Value="0"/>
                                                            <On Platform="Android" Value="0"/>
                                                            <On Platform="WinUI" Value="0"/>
                                                        </OnPlatform>
                                                    </Image.Rotation>
                                                </Image>
                                            </Border>
                                            <Grid IsVisible="{Binding Photo2, Converter={StaticResource IsNullConverter}}"
                                                  InputTransparent="True"
                                                  Margin="8">
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="End"/>
                                            </Grid>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="12,10,12,14">
                                            <!-- Capture -->
                                            <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                            <!-- Select -->
                                            <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- ── PHOTO 3: RIGHT PROFILE ── -->
                                <Border Style="{StaticResource PhotoCard}">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Padding="16,14,16,10">
                                            <Label Grid.Column="0"
                                                   Text="3. RIGHT PROFILE"
                                                   Style="{StaticResource SlotLabel}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="REQUIRED"
                                                   FontFamily="Monospace"
                                                   FontSize="9"
                                                   CharacterSpacing="2"
                                                   TextColor="{StaticResource Outline}"
                                                   VerticalOptions="Center"/>
                                        </Grid>

                                        <Grid HeightRequest="200" Margin="12,0">
                                            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource SurfaceVariant}"
                                                    IsVisible="{Binding Photo3, Converter={StaticResource IsNullConverter}}">
                                                <VerticalStackLayout VerticalOptions="Center"
                                                                     HorizontalOptions="Center"
                                                                     Spacing="8">
                                                    <Image Source="icon_person_profile_right.png"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               HorizontalOptions="Center"/>

                                                    <Label Text="No photo captured"
                                                           FontFamily="Inter"
                                                           FontSize="12"
                                                           TextColor="{StaticResource Outline}"
                                                           HorizontalOptions="Center"/>
                                                </VerticalStackLayout>
                                            </Border>
                                            <Border BackgroundColor="Black"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="{StaticResource PrimaryContainer}"
                                                    StrokeThickness="2"
                                                    IsVisible="{Binding Photo3, Converter={StaticResource IsNotNullConverter}}">
                                                <Image Source="{Binding Photo3}"
                                                       Aspect="AspectFill">
                                                    <Image.Rotation>
                                                        <OnPlatform x:TypeArguments="x:Double">
                                                            <On Platform="iOS" Value="0"/>
                                                            <On Platform="Android" Value="0"/>
                                                            <On Platform="WinUI" Value="0"/>
                                                        </OnPlatform>
                                                    </Image.Rotation>
                                                </Image>
                                            </Border>
                                            <Grid IsVisible="{Binding Photo3, Converter={StaticResource IsNullConverter}}"
                                                  InputTransparent="True"
                                                  Margin="8">
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="Start"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="Start" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="2" WidthRequest="20"
                                                         HorizontalOptions="End" VerticalOptions="End"/>
                                                <BoxView Color="{StaticResource Primary}" HeightRequest="20" WidthRequest="2"
                                                         HorizontalOptions="End" VerticalOptions="End"/>
                                            </Grid>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="12,10,12,14">
                                            <!-- Capture -->
                                            <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                            <!-- Select -->
                                            <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>

                            <!-- ── STATUS CARD ── -->
                            <Border BackgroundColor="{Binding StatusColor, Converter={StaticResource ColorToLightColorConverter}}"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="{Binding StatusColor}"
                                    StrokeThickness="1"
                                    Padding="16,14"
                                    IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}">
                                <VerticalStackLayout Spacing="10">
                                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                                       IsVisible="{Binding IsLoading}"
                                                       Color="{Binding StatusColor}"
                                                       HeightRequest="28"
                                                       WidthRequest="28"
                                                       HorizontalOptions="Center"/>
                                    <Label Text="{Binding StatusMessage}"
                                           FontFamily="Inter"
                                           FontAttributes="Bold"
                                           FontSize="13"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{Binding StatusColor}"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- ── ACTION BUTTONS ── -->
                            <VerticalStackLayout Spacing="12" Margin="0,4,0,0">
                                <!-- Primary: Register / Update -->
                                <Button Text="{Binding IsEditMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='Update User|Complete Registration'}"
                                        Command="{Binding RegisterUserCommand}"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="{StaticResource OnPrimary}"
                                        FontFamily="Inter"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        CornerRadius="32"
                                        HeightRequest="60"
                                        HorizontalOptions="Fill">
                                    <Button.Shadow>
                                        <Shadow Brush="#0056BB" Offset="0,8" Radius="24" Opacity="0.28"/>
                                    </Button.Shadow>
                                </Button>

                                <!-- Secondary: Reset / Cancel -->
                                <Button Text="{Binding IsEditMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='Cancel|Reset Form'}"
                                        Command="{Binding ResetFormCommand}"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource OnSurfaceVariant}"
                                        FontFamily="Inter"
                                        FontSize="14"
                                        CornerRadius="32"
                                        HeightRequest="48"
                                        BorderColor="{StaticResource OutlineVariant}"
                                        BorderWidth="1"
                                        HorizontalOptions="Fill"/>
                            </VerticalStackLayout>

                            <!-- ── INFO FOOTER ── -->
                            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                    StrokeShape="RoundRectangle 14"
                                    Stroke="Transparent"
                                    Padding="14,12">
                                <Label Text="ℹ️  All fields and 3 photos are required for successful face recognition"
                                       FontFamily="Inter"
                                       FontSize="12"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                    <!-- end main card -->

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
        <!-- end form grid -->

        <!-- CAMERA PREVIEW OVERLAY -->
        <Grid IsVisible="{Binding IsCameraPreviewVisible}"
              BackgroundColor="Black">

            <camera:CameraView x:Name="cameraView"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill"/>

            <!-- Top info bar -->
            <Border BackgroundColor="#CC000000"
                    StrokeShape="Rectangle"
                    Stroke="Transparent"
                    VerticalOptions="Start"
                    Padding="20,48,20,18">
                <Grid ColumnDefinitions="48,*,48">
                    <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding ActivePhotoSlot, StringFormat='📸  Photo {0}'}"
                               TextColor="White"
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="20"
                               HorizontalOptions="Center"/>
                        <Label Text="Center your face in the frame"
                               TextColor="#CCFFFFFF"
                               FontFamily="Inter"
                               FontSize="13"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <!-- Flip camera button -->
                    <Border Grid.Column="2"
                            BackgroundColor="#33FFFFFF"
                            StrokeShape="RoundRectangle 24"
                            Stroke="Transparent"
                            WidthRequest="44"
                            HeightRequest="44"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Button x:Name="flipCameraButton"
                                Text="🔄"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="18"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Clicked="OnFlipCameraClicked"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Bottom shutter bar -->
            <Border BackgroundColor="#CC000000"
                    StrokeShape="Rectangle"
                    Stroke="Transparent"
                    VerticalOptions="End"
                    Padding="24,20,24,48">
                <VerticalStackLayout Spacing="16">
                    <!-- Shutter ring + button -->
                    <Border StrokeShape="Ellipse"
                            Stroke="White"
                            StrokeThickness="3"
                            BackgroundColor="Transparent"
                            WidthRequest="84"
                            HeightRequest="84"
                            HorizontalOptions="Center">
                        <Button x:Name="shutterButton"
                                BackgroundColor="White"
                                CornerRadius="34"
                                WidthRequest="68"
                                HeightRequest="68"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Clicked="OnCaptureClicked"/>
                    </Border>
                    <!-- Cancel -->
                    <Button Text="✕   Cancel"
                            Command="{Binding CancelCameraPreviewCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            BorderColor="Transparent"
                            FontFamily="Inter"
                            FontSize="15"
                            HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

        </Grid>
        <!-- end camera overlay -->

    </Grid>
</ContentPage>
