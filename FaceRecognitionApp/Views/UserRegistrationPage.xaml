<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceRecognitionApp.ViewModels"
             x:Class="FaceRecognitionApp.Views.UserRegistrationPage"
             x:DataType="viewmodels:UserRegistrationViewModel"
             Title=""
             BackgroundColor="#F7F9FF"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    
    <ContentPage.Resources>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#EDEFF5"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HeightRequest" Value="56"/>
        </Style>

        <Style x:Key="FieldEntry" TargetType="Entry">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="TextColor" Value="#171C22"/>
            <Setter Property="PlaceholderColor" Value="#C2C6D5"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="MinimumHeightRequest" Value="56"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Focused"/>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="#171C22"/>
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="PhotoBox" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#F0F4FC"/>
            <Setter Property="Stroke" Value="#DEE3EB"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
            <Setter Property="HeightRequest" Value="200"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
        </Style>

        <Style x:Key="CaptureBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#0056BB"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="CharacterSpacing" Value="1"/>
        </Style>

        <Style x:Key="SelectBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#FFFFFF"/>
            <Setter Property="TextColor" Value="#171C22"/>
            <Setter Property="BorderColor" Value="#C2C6D5"/>
            <Setter Property="BorderWidth" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="44"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="CharacterSpacing" Value="1"/>
        </Style>

        <Style x:Key="SectionTag" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextColor" Value="#727784"/>
            <Setter Property="CharacterSpacing" Value="2"/>
        </Style>

        <Style x:Key="AngleTitle" TargetType="Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextColor" Value="#0056BB"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="CharacterSpacing" Value="2"/>
        </Style>

    </ContentPage.Resources>

    <Grid>

        <ScrollView IsVisible="{Binding IsCameraPreviewVisible, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <Grid ColumnDefinitions="Auto,*"
                      BackgroundColor="#FFFFFF"
                      Padding="20,16"
                      ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="#EFF6FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="Start"
                            VerticalOptions="Center">

                        <Image Source="arrow_back.png"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">

                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Image.GestureRecognizers>

                        </Image>

                    </Border>

                    <Label Grid.Column="1"
                           Text="AVIVANEXT"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#0056BB"
                           CharacterSpacing="2"
                           VerticalOptions="Center"/>
                </Grid>

                <VerticalStackLayout Padding="20,20,20,12"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <Label Text="Register User"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#0056BB"
                           HorizontalOptions="Center"/>
                    <Label Text="Enter details for multi-angle biometric enrollment"
                           FontSize="13"
                           TextColor="#424753"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 40"
                        Margin="16,0,16,32"
                        Padding="24">
                    <VerticalStackLayout Spacing="28">

                        <!-- ── IDENTIFICATION ENTRY ── -->
                        <VerticalStackLayout Spacing="12">

                            <Label Text="IDENTIFICATION ENTRY"
                                   FontSize="12"
                                   TextColor="#727784"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"/>

                            <!-- User ID -->
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="User ID"
                                       Text="{Binding UserId}"
                                       BackgroundColor="Transparent"/>
                            </Border>

                            <!-- Full Name -->
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="Full Name"
                                       Text="{Binding Name}"
                                       BackgroundColor="Transparent"/>
                            </Border>

                            <!-- Date -->
                            <Border Style="{StaticResource FieldBorder}">
                                <DatePicker Date="{Binding DateOfBirth}"
                                            BackgroundColor="Transparent"
                                            TextColor="#171C22"/>
                            </Border>

                        </VerticalStackLayout>
                        
                        <!-- ── MULTI-ANGLE BIOMETRIC CAPTURE ── -->
                        <VerticalStackLayout Spacing="20">

                            <Label Text="MULTI-ANGLE BIOMETRIC CAPTURE"
                                   Style="{StaticResource SectionTag}"/>
                            <BoxView HeightRequest="1" Color="#DEE3EB"/>

                            <!-- ── PHOTO 1: FRONT FACE ── -->
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="1. FRONT FACE"
                                           Style="{StaticResource AngleTitle}"/>

                                    <Label Grid.Column="1"
                                           Text="REQUIRED"
                                           FontSize="10"
                                           TextColor="#727784"
                                           FontAttributes="Bold"
                                           CharacterSpacing="1"/>       
                                </Grid>

                                <!-- Photo preview — when captured -->
                                <Border Style="{StaticResource PhotoBox}"
                                        Stroke="{StaticResource Secondary}"
                                        IsVisible="{Binding Photo1, Converter={StaticResource IsNotNullConverter}}">
                                    <Image Source="{Binding Photo1}" Aspect="AspectFill"/>
                                </Border>

                                <!-- Placeholder -->
                                <Border Style="{StaticResource PhotoBox}"
                                        IsVisible="{Binding Photo1, Converter={StaticResource IsNullConverter}}">
                                    <VerticalStackLayout 
                                        VerticalOptions="Center" 
                                        HorizontalOptions="Center" 
                                        Spacing="8">

                                        <Image Source="icon_person.png"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               HorizontalOptions="Center"/>

                                        <Label Text="No photo captured"
                                               FontSize="12"
                                               TextColor="#727784"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Buttons -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                    <!-- Capture -->
                                    <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                    <!-- Select -->
                                    <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                </Grid>
                            </VerticalStackLayout>

                            <!-- ── PHOTO 2: LEFT PROFILE ── -->
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="2. LEFT PROFILE" Style="{StaticResource AngleTitle}"/>
                                    <Label Grid.Column="1" Text="REQUIRED" FontSize="10" TextColor="#727784" FontAttributes="Bold" CharacterSpacing="1"/>
                                </Grid>

                                <Border Style="{StaticResource PhotoBox}"
                                        Stroke="{StaticResource Secondary}"
                                        IsVisible="{Binding Photo2, Converter={StaticResource IsNotNullConverter}}">
                                    <Image Source="{Binding Photo2}" Aspect="AspectFill"/>
                                </Border>

                                <Border Style="{StaticResource PhotoBox}"
                                        IsVisible="{Binding Photo2, Converter={StaticResource IsNullConverter}}">
                                    <VerticalStackLayout 
                                            VerticalOptions="Center" 
                                            HorizontalOptions="Center" 
                                            Spacing="8">

                                        <Image Source="icon_person_profile_left.png"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               HorizontalOptions="Center"/>

                                        <Label Text="No photo captured"
                                               FontSize="12"
                                               TextColor="#727784"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                    <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                    <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                </Grid>
                            </VerticalStackLayout>

                            <!-- ── PHOTO 3: RIGHT PROFILE ── -->
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="3. RIGHT PROFILE" Style="{StaticResource AngleTitle}"/>
                                    <Label Grid.Column="1" Text="REQUIRED" FontSize="10" TextColor="#727784" FontAttributes="Bold" CharacterSpacing="1"/>
                                </Grid>

                                <Border Style="{StaticResource PhotoBox}"
                                        Stroke="{StaticResource Secondary}"
                                        IsVisible="{Binding Photo3, Converter={StaticResource IsNotNullConverter}}">
                                    <Image Source="{Binding Photo3}" Aspect="AspectFill"/>
                                </Border>

                                <Border Style="{StaticResource PhotoBox}"
                                        IsVisible="{Binding Photo3, Converter={StaticResource IsNullConverter}}">
                                    <VerticalStackLayout 
                                            VerticalOptions="Center" 
                                            HorizontalOptions="Center" 
                                            Spacing="8">

                                        <Image Source="icon_person_profile_right.png"
                                               HeightRequest="52"
                                               WidthRequest="52"
                                               HorizontalOptions="Center"/>

                                        <Label Text="No photo captured"
                                               FontSize="12"
                                               TextColor="#727784"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                    <Button Grid.Column="0"
                                            Text="CAPTURE"
                                            ImageSource="icon_camera.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource CaptureBtn}"
                                            Command="{Binding StartCapturePhoto1Command}" />

                                    <Button Grid.Column="1"
                                            Text="SELECT"
                                            ImageSource="icon_upload.png"
                                            ContentLayout="Left,8"
                                            Style="{StaticResource SelectBtn}"
                                            Command="{Binding PickPhoto1Command}" />

                                </Grid>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                        <!-- ── SUCCESS ALERT ── -->
                        <Border BackgroundColor="#F0FFF4"
                                Stroke="#BBF7D0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding IsRegistrationSuccessful}">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="✅" FontSize="22" VerticalOptions="Center"/>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="User Successfully Registered"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#166534"/>
                                    <Label Text="Multi-view biometric identity synchronized."
                                           FontSize="12"
                                           TextColor="#166534"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- ── STATUS CARD ── -->
                        <Border BackgroundColor="#EFF6FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}">
                            <VerticalStackLayout Spacing="8">
                                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                                   IsVisible="{Binding IsLoading}"
                                                   Color="#0056BB"
                                                   HeightRequest="28"
                                                   WidthRequest="28"
                                                   HorizontalOptions="Center"/>
                                <Label Text="{Binding StatusMessage}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{Binding StatusColor}"/>
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout Spacing="12"
                                             IsVisible="{Binding IsRegistrationSuccessful, Converter={StaticResource InvertedBoolConverter}}">
                            <Button Text="Complete Registration"
                                    TextColor="#FFFFFF"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    HeightRequest="64"
                                    CornerRadius="32"
                                    Command="{Binding RegisterUserCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2E6FD8" Offset="0.0"/>
                                        <GradientStop Color="#0056BB" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <Button Text="{Binding IsEditMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='Cancel|Reset'}"
                                    BackgroundColor="#F0F4FC"
                                    TextColor="#0056BB"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    HeightRequest="52"
                                    CornerRadius="26"
                                    Command="{Binding ResetFormCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- ── POST-REGISTRATION DASHBOARD BUTTON ── -->
                        <Button Text="System Dashboard  →"
                                TextColor="#FFFFFF"
                                FontSize="17"
                                FontAttributes="Bold"
                                HeightRequest="64"
                                CornerRadius="32"
                                BackgroundColor="#0056BB"
                                Clicked="OnDashboardClicked"
                                IsVisible="{Binding IsRegistrationSuccessful}"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- CAMERA PREVIEW OVERLAY -->
        <Grid IsVisible="{Binding IsCameraPreviewVisible}"
              BackgroundColor="Black">

            <Border BackgroundColor="#CC000000"
                    VerticalOptions="Start"
                    Padding="20,48,20,16">
                <Grid ColumnDefinitions="48,*,48">
                    <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding ActivePhotoSlot, StringFormat='📸 Photo {0}'}"
                               TextColor="White" FontSize="22" FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Center your face in the frame"
                               TextColor="#CCFFFFFF" FontSize="14"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Button x:Name="flipCameraButton"
                            Grid.Column="2"
                            Text="🔄"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="22"
                            WidthRequest="48" HeightRequest="48"
                            Padding="0"
                            VerticalOptions="Center" HorizontalOptions="Center"
                            Clicked="OnFlipCameraClicked"/>
                </Grid>
            </Border>

            <VerticalStackLayout VerticalOptions="End"
                                 Padding="24,0,24,52"
                                 Spacing="20"
                                 BackgroundColor="#CC000000">
                <Border StrokeShape="Ellipse"
                        Stroke="White" StrokeThickness="3"
                        BackgroundColor="Transparent"
                        WidthRequest="88" HeightRequest="88"
                        HorizontalOptions="Center">
                    <Button x:Name="shutterButton"
                            BackgroundColor="White"
                            CornerRadius="36"
                            WidthRequest="72" HeightRequest="72"
                            HorizontalOptions="Center" VerticalOptions="Center"
                            Clicked="OnCaptureClicked"/>
                </Border>
                <Button Text="✕  Cancel"
                        Command="{Binding CancelCameraPreviewCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White" BorderColor="Transparent"
                        FontSize="16" HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
