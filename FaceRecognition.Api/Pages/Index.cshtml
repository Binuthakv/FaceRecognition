@page
@{
    ViewData["Title"] = "Face Recognition API";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            width: 100%;
        }

        .hero {
            text-align: center;
            color: white;
            margin-bottom: 50px;
        }

        .hero h1 {
            font-size: 48px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }

        .hero p {
            font-size: 18px;
            opacity: 0.9;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
        }

        .card-icon {
            font-size: 48px;
            margin-bottom: 20px;
        }

        .card h2 {
            color: #333;
            margin-bottom: 10px;
            font-size: 24px;
        }

        .card p {
            color: #666;
            font-size: 14px;
            line-height: 1.6;
            flex-grow: 1;
        }

        .card-link {
            margin-top: 20px;
            padding: 12px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            text-align: center;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .card-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

        .docs {
            background: white;
            border-radius: 8px;
            padding: 30px;
            margin-top: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .docs h3 {
            color: #333;
            margin-bottom: 20px;
            font-size: 22px;
        }

        .endpoint {
            background: #f5f5f5;
            padding: 15px;
            border-left: 4px solid #667eea;
            margin-bottom: 15px;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
        }

        .method {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 3px;
            margin-right: 10px;
            font-weight: 600;
            font-size: 11px;
        }

        .method-get {
            background: #28a745;
            color: white;
        }
    </style>
    <style>
        @@media (max-width: 768px) {
            .hero h1 {
                font-size: 32px;
            }

            .hero p {
                font-size: 16px;
            }

            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="hero">
            <h1>🔐 Face Recognition API</h1>
            <p>Secure Identity System with Attendance Tracking</p>
        </div>

        <div class="grid">
            <a href="/AttendanceList" class="card">
                <div class="card-icon">📋</div>
                <h2>Attendance Records</h2>
                <p>View all attendance records in a table format with user information, scan times, and processing status.</p>
                <button class="card-link">View Records →</button>
            </a>

            <a href="/UserWorkingHoursList" class="card">
                <div class="card-icon">⏱️</div>
                <h2>Working Hours Analysis</h2>
                <p>View and analyze user working hours with date-wise and user-wise filtering capabilities.</p>
                <button class="card-link">View Working Hours →</button>
            </a>
        </div>
    </div>
</body>
</html>
