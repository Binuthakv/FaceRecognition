@page
@model FaceRecognitionApp.Api.Pages.SetupModel
@{
    ViewData["Title"] = "Admin Setup | AVIVANEXT";
}

<!DOCTYPE html>
<html class="h-full overflow-hidden" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "surface-container-high": "#e2e7ff",
        "primary-container": "#0052ff",
        "on-error-container": "#93000a",
        "primary-fixed": "#dde1ff",
        "primary": "#003ec7",
        "on-secondary-container": "#005266",
        "inverse-surface": "#283044",
        "error": "#ba1a1a",
        "outline-variant": "#c3c5d9",
        "error-container": "#ffdad6",
        "tertiary-fixed-dim": "#bfc6dd",
        "secondary-fixed-dim": "#4cd6ff",
        "inverse-primary": "#b7c4ff",
        "on-background": "#131b2e",
        "surface-container-highest": "#dae2fd",
        "surface-bright": "#faf8ff",
        "on-error": "#ffffff",
        "on-tertiary-fixed": "#141b2c",
        "primary-fixed-dim": "#b7c4ff",
        "on-primary-fixed": "#001452",
        "tertiary": "#474e61",
        "on-secondary-fixed": "#001f28",
        "secondary": "#00677f",
        "on-primary": "#ffffff",
        "surface": "#faf8ff",
        "on-secondary-fixed-variant": "#004e60",
        "surface-container-low": "#f2f3ff",
        "background": "#faf8ff",
        "tertiary-fixed": "#dbe2fa",
        "surface-variant": "#dae2fd",
        "secondary-fixed": "#b7eaff",
        "on-primary-container": "#dfe3ff",
        "surface-dim": "#d2d9f4",
        "on-tertiary-container": "#dde4fc",
        "surface-container": "#eaedff",
        "surface-tint": "#004ced",
        "outline": "#737688",
        "on-tertiary-fixed-variant": "#3f4759",
        "tertiary-container": "#5e667a",
        "secondary-container": "#00ccf9",
        "on-surface": "#131b2e",
        "inverse-on-surface": "#eef0ff",
        "on-surface-variant": "#434656",
        "on-primary-fixed-variant": "#0038b6",
        "surface-container-lowest": "#ffffff",
        "on-secondary": "#ffffff",
        "on-tertiary": "#ffffff"
        },
        "borderRadius": {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
        },
        "spacing": {
        "lg": "48px",
        "xl": "80px",
        "xs": "4px",
        "margin": "32px",
        "base": "8px",
        "sm": "12px",
        "md": "24px",
        "gutter": "24px"
        },
        "fontFamily": {
        "label-sm": ["Inter"],
        "body-lg": ["Inter"],
        "code": ["Inter"],
        "headline-xl": ["Inter"],
        "headline-lg": ["Inter"],
        "body-md": ["Inter"],
        "headline-md": ["Inter"]
        },
        "fontSize": {
        "label-sm": ["14px", {"lineHeight": "1", "letterSpacing": "0.01em", "fontWeight": "500"}],
        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
        "code": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
        "headline-xl": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
        "headline-lg": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "600"}],
        "body-md": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
        "headline-md": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}]
        }
        },
        },
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        }

        body {
        font-family: 'Inter', sans-serif;
        overflow: hidden;
        height: 100vh;
        }
    </style>
</head>
<body class="bg-surface h-full flex flex-col overflow-hidden">

    <main class="flex-grow flex flex-col md:flex-row h-full overflow-hidden">

        <!-- ── Left Section: Visual & Context ── -->
        <section class="md:w-5/12 bg-surface-container-low flex flex-col p-md md:p-xl justify-between border-b md:border-b-0 md:border-r border-outline-variant/30 overflow-hidden shrink-0">
            <div>
                <h1 class="font-headline-lg md:font-headline-xl text-headline-md md:text-headline-xl text-primary mb-sm">Admin Setup</h1>
                <p class="font-body-lg text-body-md md:text-body-lg text-on-surface-variant mb-md">Create your first administrator account</p>

                <div class="bg-surface-container-lowest p-md rounded-xl shadow-[0_4px_20px_rgba(0,62,199,0.05)] border border-primary/10">
                    <div class="flex items-start gap-sm">
                        <div>
                            <h3 class="font-label-sm text-label-sm text-primary mb-xs uppercase tracking-wider">Setup Instructions</h3>
                            <p class="font-body-md text-body-md text-on-surface-variant">
                                Create the administrator account for the Face Recognition System.
                                This account will have full access to all features.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="relative flex-grow flex items-center justify-center py-md overflow-hidden">
                <div class="w-full max-w-[300px] md:max-w-none h-auto md:h-full max-h-[400px] rounded-2xl overflow-hidden shadow-xl border border-primary/5 bg-white">
                    <img alt="High-tech face recognition biometric scan illustration"
                         class="w-full h-full object-contain"
                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5R0Vu1IpYlYxSDsfRvBhLmzB4C_NCPV2YJt5KCldIgirAmMjB3OVsjT74s-lH0IA_qYY4HX8ro0a2qkAF104A60eR7wtRbeMApNuseFJdjhncxhTMpuVakLDikNN-6jk3xt7TGtZrMbhQmC0BKZQNhS55sKJ-AMQrhQj9mDEJLNNv-e7kagb7MnGY5gK1RYTRuqfHtALkX_FllN7gg1SK0Y-2fbL9F51cN027_nWi6y5D3tCm5xViaIPTdXu3f0HI1DlHkehzIfJU" />
                </div>
            </div>

            <div class="flex items-center gap-xs pt-md md:pt-0 shrink-0">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                <span class="font-label-sm text-[10px] md:text-label-sm text-primary font-bold tracking-widest uppercase">Secured by Avivanext</span>
            </div>
        </section>

        <!-- ── Right Section: Registration Form ── -->
        <section class="flex-grow flex items-center justify-center bg-surface-container-lowest p-md md:p-xl relative overflow-y-auto">
            <div class="w-full max-w-lg flex flex-col justify-center py-md">

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="flex items-start gap-2 px-4 py-3 mb-md rounded-lg bg-error-container border border-error/30 text-on-error-container font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-[18px] mt-px shrink-0">error</span>
                        <span>@Model.ErrorMessage</span>
                    </div>
                }

                <!-- Success Message -->
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="flex items-start gap-2 px-4 py-3 mb-md rounded-lg bg-[#d4edda] border border-[#28a745]/30 text-[#155724] font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-[18px] mt-px shrink-0">check_circle</span>
                        <div>
                            <span>@Model.SuccessMessage</span>
                            <p class="mt-2">
                                <a href="/Login" class="font-semibold underline">Click here to login →</a>
                            </p>
                        </div>
                    </div>
                }

                <!-- Admin Already Exists Banner -->
                @if (Model.AdminExists)
                {
                    <div class="flex items-start gap-2 px-4 py-3 mb-md rounded-lg bg-surface-container border border-primary/20 text-on-surface-variant font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-[18px] mt-px shrink-0 text-primary">info</span>
                        <span>
                            An admin account already exists. Please
                            <a href="/Login" class="text-primary font-semibold hover:underline">login here</a>.
                        </span>
                    </div>
                }
                else
                {
                    <form method="post" asp-page="Setup" id="setupForm" class="space-y-md">
                        @Html.AntiForgeryToken()

                        <div class="mb-sm">
                            <h2 class="text-headline-md font-headline-md text-on-surface">Account Details</h2>
                            <div class="h-1 w-12 bg-primary mt-xs rounded-full"></div>
                        </div>

                        <!-- Username -->
                        <div class="space-y-xs">
                            <label class="font-label-sm text-label-sm text-on-surface-variant" for="username">Username</label>
                            <input class="w-full px-md py-sm rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-body-md text-body-md"
                                   type="text"
                                   id="username"
                                   name="Username"
                                   placeholder="e.g. jsmith_admin"
                                   value="@Model.Username"
                                   required
                                   minlength="3"
                                   maxlength="50" />
                            <p class="text-[12px] text-outline font-label-sm">This will be your unique identifier within the system.</p>
                        </div>

                        <!-- Email -->
                        <div class="space-y-xs">
                            <label class="font-label-sm text-label-sm text-on-surface-variant" for="email">Email Address</label>
                            <input class="w-full px-md py-sm rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-body-md text-body-md"
                                   type="email"
                                   id="email"
                                   name="Email"
                                   placeholder="admin@company.com"
                                   value="@Model.Email"
                                   required />
                            <p class="text-[12px] text-outline font-label-sm">Used for password recovery and critical system alerts.</p>
                        </div>

                        <!-- Password + Confirm Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                            <div class="space-y-xs">
                                <label class="font-label-sm text-label-sm text-on-surface-variant" for="password">Password</label>
                                <input class="w-full px-md py-sm rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-body-md text-body-md"
                                       type="password"
                                       id="password"
                                       name="Password"
                                       placeholder="••••••••"
                                       required
                                       minlength="8" />
                            </div>
                            <div class="space-y-xs">
                                <label class="font-label-sm text-label-sm text-on-surface-variant" for="confirmPassword">Confirm Password</label>
                                <input class="w-full px-md py-sm rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-body-md text-body-md"
                                       type="password"
                                       id="confirmPassword"
                                       name="ConfirmPassword"
                                       placeholder="••••••••"
                                       required />
                            </div>
                        </div>

                        <!-- Password Requirements -->
                        <div class="bg-surface-container p-sm rounded-lg">
                            <p class="font-label-sm text-[12px] text-on-surface-variant mb-xs">Password must include:</p>
                            <ul class="grid grid-cols-2 gap-xs">
                                <li class="flex items-center text-[11px] text-outline font-label-sm">
                                    <span class="material-symbols-outlined text-[14px] mr-1 text-secondary">check_circle</span>
                                    8+ characters
                                </li>
                                <li class="flex items-center text-[11px] text-outline font-label-sm">
                                    <span class="material-symbols-outlined text-[14px] mr-1">radio_button_unchecked</span>
                                    Special symbol
                                </li>
                                <li class="flex items-center text-[11px] text-outline font-label-sm">
                                    <span class="material-symbols-outlined text-[14px] mr-1">radio_button_unchecked</span>
                                    Upper/Lower case
                                </li>
                                <li class="flex items-center text-[11px] text-outline font-label-sm">
                                    <span class="material-symbols-outlined text-[14px] mr-1">radio_button_unchecked</span>
                                    Number
                                </li>
                            </ul>
                        </div>

                        <!-- Role Selection -->
                        <div class="space-y-xs">
                            <label class="font-label-sm text-label-sm text-on-surface-variant" for="role">System Role</label>
                            <div class="relative">
                                <select class="w-full px-md py-sm rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-body-md text-body-md appearance-none bg-no-repeat bg-[right_1rem_center]"
                                        id="role"
                                        name="Role"
                                        required
                                        style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23737688%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E');">
                                    <option value="Admin" selected="@(Model.Role == "Admin" ? "selected" : null)">Admin (Full Access)</option>
                                    <option value="Manager" selected="@(Model.Role == "Manager" ? "selected" : null)">Manager (Read/Write)</option>
                                    <option value="Viewer" selected="@(Model.Role == "Viewer" ? "selected" : null)">Viewer (Read Only)</option>
                                </select>
                            </div>
                        </div>

                        <!-- Submit + Back -->
                        <div class="pt-md flex flex-col items-center gap-md">
                            <button class="w-full bg-primary text-on-primary py-sm rounded-lg font-medium text-body-md hover:bg-on-primary-fixed-variant transition-colors shadow-md active:scale-[0.98]"
                                    type="submit"
                                    id="submitBtn">
                                Create Admin Account
                            </button>
                            <a class="inline-flex items-center text-primary font-label-sm text-label-sm hover:underline group transition-all" href="/Login">
                                Back to Login
                            </a>
                        </div>

                    </form>
                }

            </div>
        </section>

    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('setupForm');
        if (form) {
        form.addEventListener('submit', function () {
        console.log('Setup form submit event triggered');
        });
        }
        });
    </script>

</body>
</html>
