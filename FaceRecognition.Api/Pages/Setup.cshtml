@page
@model FaceRecognitionApp.Api.Pages.SetupModel
@{
    ViewData["Title"] = "Admin Setup | AVIVANEXT";
    Layout = "~/Pages/Shared/_PublicLayout.cshtml";
}

<!-- Main Content Area -->
<main class="flex-grow flex items-center justify-center px-gutter">
    <div class="w-full max-w-[400px] login-card p-md">

        <!-- Brand Header -->
        <div class="flex flex-col items-center mb-md">
            <span class="material-symbols-outlined text-[48px] text-primary mb-2">face_6</span>
            <h1 class="font-headline-md text-headline-md text-primary mb-xs tracking-tight">AVIVANEXT</h1>
            <p class="font-label-sm text-label-sm text-outline">Admin Setup</p>
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error flex items-start gap-2 px-4 py-3 mb-sm rounded-lg font-label-sm text-label-sm">
                <span class="material-symbols-outlined text-[18px] mt-px shrink-0">error</span>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        <!-- Success Message -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert-success flex items-start gap-2 px-4 py-3 mb-sm rounded-lg font-label-sm text-label-sm">
                <span class="material-symbols-outlined text-[18px] mt-px shrink-0">check_circle</span>
                <div>
                    <span>@Model.SuccessMessage</span>
                    <p class="mt-2">
                        <a href="/Login" class="font-semibold underline">Click here to login →</a>
                    </p>
                </div>
            </div>
        }

        <!-- Admin Already Exists Banner -->
        @if (Model.AdminExists)
        {
            <div class="flex items-start gap-2 px-4 py-3 mb-sm rounded-lg bg-surface-container border border-primary/20 text-on-surface-variant font-label-sm text-label-sm">
                <span class="material-symbols-outlined text-[18px] mt-px shrink-0 text-primary">info</span>
                <span>
                    An admin account already exists. Please
                    <a href="/Login" class="text-primary font-semibold hover:underline">login here</a>.
                </span>
            </div>
        }
        else
        {
            <!-- Register Form -->
            <form method="post" asp-page="Setup" id="setupForm" class="space-y-sm">
                @Html.AntiForgeryToken()

                <!-- Username -->
                <div class="flex flex-col gap-xs">
                    <label class="font-label-sm text-label-sm text-on-surface-variant ml-1" for="username">Username</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">person</span>
                        <input class="form-input w-full pl-10 pr-4 py-3 bg-surface-bright rounded-lg font-body-md text-body-md text-on-surface"
                               type="text"
                               id="username"
                               name="Username"
                               placeholder="Enter a username"
                               value="@Model.Username"
                               required
                               minlength="3"
                               maxlength="50"
                               autocomplete="username"
                               autofocus />
                    </div>
                </div>

                <!-- Email -->
                <div class="flex flex-col gap-xs">
                    <label class="font-label-sm text-label-sm text-on-surface-variant ml-1" for="email">Email Address</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">mail</span>
                        <input class="form-input w-full pl-10 pr-4 py-3 bg-surface-bright rounded-lg font-body-md text-body-md text-on-surface"
                               type="email"
                               id="email"
                               name="Email"
                               placeholder="Enter your email"
                               value="@Model.Email"
                               required
                               autocomplete="email" />
                    </div>
                </div>

                <!-- Password -->
                <div class="flex flex-col gap-xs">
                    <label class="font-label-sm text-label-sm text-on-surface-variant ml-1" for="password">Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">lock</span>
                        <input class="form-input w-full pl-10 pr-4 py-3 bg-surface-bright rounded-lg font-body-md text-body-md text-on-surface"
                               type="password"
                               id="password"
                               name="Password"
                               placeholder="••••••••"
                               required
                               minlength="8"
                               autocomplete="new-password" />
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="flex flex-col gap-xs">
                    <label class="font-label-sm text-label-sm text-on-surface-variant ml-1" for="confirmPassword">Confirm Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">lock_reset</span>
                        <input class="form-input w-full pl-10 pr-4 py-3 bg-surface-bright rounded-lg font-body-md text-body-md text-on-surface"
                               type="password"
                               id="confirmPassword"
                               name="ConfirmPassword"
                               placeholder="••••••••"
                               required
                               autocomplete="new-password" />
                    </div>
                </div>

                <!-- System Role -->
                <div class="flex flex-col gap-xs">
                    <label class="font-label-sm text-label-sm text-on-surface-variant ml-1" for="role">System Role</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">shield_person</span>
                        <select class="form-input w-full pl-10 pr-4 py-3 bg-surface-bright rounded-lg font-body-md text-body-md text-on-surface appearance-none bg-no-repeat bg-[right_1rem_center]"
                                id="role"
                                name="Role"
                                required
                                style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23737688%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E');">
                            <option value="Admin" selected="@(Model.Role == "Admin" ? "selected" : null)">Admin</option>
                            <option value="Manager" selected="@(Model.Role == "Manager" ? "selected" : null)">Manager</option>
                            <option value="Viewer" selected="@(Model.Role == "Viewer" ? "selected" : null)">Viewer</option>
                        </select>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit"
                        class="w-full py-3 bg-primary text-on-primary font-label-sm text-label-sm font-semibold rounded-lg shadow-sm border border-primary active:scale-[0.98] transition-transform flex items-center justify-center"
                        id="submitBtn">
                    Create Admin Account
                </button>

                <!-- Back to Login -->
                <div class="pt-xs text-center">
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Already have an account? </span>
                    <a class="font-label-sm text-label-sm text-primary font-semibold hover:underline" href="/Login">
                        Sign in
                    </a>
                </div>

            </form>
        }

    </div>
</main>

<!-- Footer -->
<footer class="site-footer fixed bottom-0 w-full flex items-center justify-center px-8 py-4">
    <div class="font-inter text-xs tracking-wide text-slate-500 text-center">
        © 2026 AvivaNext. All rights reserved.
    </div>
</footer>

