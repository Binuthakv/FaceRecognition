@page
@model FaceRecognitionApp.Api.Pages.AdminUsersListModel
@{
    ViewData["Title"] = "AVIVANEXT | Admin Users";
    ViewData["PageLabel"] = "Manage Admin Users";
    ViewData["ActiveNav"] = "adminusers";
    ViewData["LogoutPage"] = "/Dashboard";
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<!-- Page Header -->
<div class="mb-12 flex flex-col gap-1">
    <h1 class="font-semibold" style="font-size:32px; line-height:1.2; letter-spacing:-0.01em; color:#131b2e;">Manage Admin Users</h1>
    <p style="color:#737688;">View and manage administrator accounts within the system</p>
</div>

<!-- Alert Messages -->
@* @if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert-status-green mb-6 flex items-center gap-3 px-4 py-3 rounded-xl">
        <span class="material-symbols-outlined" style="font-size:20px;">check_circle</span>
        <span class="text-sm font-medium">@Model.StatusMessage</span>
    </div>
} *@
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert-status-red mb-6 flex items-center gap-3 px-4 py-3 rounded-xl">
        <span class="material-symbols-outlined" style="font-size:20px;">error</span>
        <span class="text-sm font-medium">@Model.ErrorMessage</span>
    </div>
}



<!-- Search and Filter Card -->
<form method="get" asp-page="AdminUsersList">
    <div class="flex items-center justify-end gap-2 mb-6" style="flex-wrap:nowrap;">
        <input type="text" name="searchQuery"
               placeholder="Search by username or email..."
               value="@Model.SearchQuery"
               class="form-input px-3 py-2 rounded-lg text-sm"
               style="width:220px; flex-shrink:0; border:1px solid #c3c5d9;" />
        <select name="sortBy" class="form-input px-3 py-2 rounded-lg text-sm"
                style="width:160px; flex-shrink:0; border:1px solid #c3c5d9;">
            <option value="username" selected="@(Model.SortBy == "username")">Username (A-Z)</option>
            <option value="email" selected="@(Model.SortBy == "email")">Email</option>
            <option value="role" selected="@(Model.SortBy == "role")">Role</option>
            <option value="created" selected="@(Model.SortBy == "created")">Recently Created</option>
            <option value="lastlogin" selected="@(Model.SortBy == "lastlogin")">Recently Logged In</option>
        </select>
        <button type="submit"
                class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
                style="background:#003ec7; color:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">search</span>
            Search
        </button>
        <a href="/AdminUsersList"
               class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
               style="border:1px solid #c3c5d9; color:#434656; background:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">close</span>
            Clear
        </a>
    </div>
</form>

<!-- Admin Users Table Card -->
<div class="glass-card rounded-xl overflow-hidden" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">
    <!-- Table Header / Controls -->
    <div class="table-controls-bar px-6 py-4 border-b flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined" style="color:#003ec7;">admin_panel_settings</span>
            <h3 class="font-semibold" style="color:#131b2e; font-size:18px;">Admin Accounts</h3>
        </div>
        <span class="text-xs font-medium" style="color:#737688;">
            Total: @Model.AdminUsers.Count
        </span>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        @if (Model.AdminUsers.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">Username</th>
                        <th class="px-6 py-4 font-medium">Email</th>
                        <th class="px-6 py-4 font-medium">Role</th>
                        <th class="px-6 py-4 font-medium">Status</th>
                        <th class="px-6 py-4 font-medium">Created Date</th>
                        <th class="px-6 py-4 font-medium">Last Login</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var admin in Model.AdminUsers)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@admin.Username</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@admin.Email</td>
                            <td class="px-6 py-4 text-sm">
                                <span class="badge-primary inline-flex px-2.5 py-1 rounded-full text-xs font-medium"
                                      style="@(admin.Role == "Admin" ? "background:#e8f5e9; color:#2e7d32;" : admin.Role == "Manager" ? "background:#fff3e0; color:#e65100;" : "background:#f3e5f5; color:#6a1b9a;")">
                                    @admin.Role
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                @if (admin.IsActive)
                                {
                                    <span class="badge-processed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#16a34a;"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-unprocessed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#ba1a1a;"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-sm" style="color:#434656;">@admin.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-4 text-sm" style="color:#434656;">
                                @if (admin.LastLoginDate.HasValue)
                                {
                                    @admin.LastLoginDate.Value.ToString("MMM dd, yyyy HH:mm")
                                }
                                else
                                {
                                    <span style="color:#999;">Never</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-16" style="color:#737688;">
                <span class="material-symbols-outlined" style="font-size:48px; color:#c3c5d9; display:block; margin-bottom:12px;">admin_panel_settings</span>
                <h3 class="font-semibold mb-1" style="color:#434656;">No Admin Users Found</h3>
                <p class="text-sm">@(string.IsNullOrWhiteSpace(Model.SearchQuery) ? "No admin users exist in the system." : "No admin users match your search criteria.")</p>
            </div>
        }
    </div>

    <!-- Table Footer -->
    <div class="table-footer-bar px-6 py-4 border-t flex justify-between items-center">
        <span class="text-xs font-medium" style="color:#737688;">
            Showing @Model.AdminUsers.Count of @Model.TotalAdminUsers admin users
        </span>
    </div>
</div>
