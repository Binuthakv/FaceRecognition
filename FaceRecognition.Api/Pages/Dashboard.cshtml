@page
@model FaceRecognitionApp.Api.Pages.DashboardModel
@{
    ViewData["Title"] = "Face Recognition API";
    ViewData["PageLabel"] = "System Dashboard";
    ViewData["ActiveNav"] = "dashboard";
    ViewData["LogoutPage"] = "Dashboard";
    ViewData["ShowRefreshBadge"] = true;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

@section CdnHead {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<!-- Hero Section -->
<div class="mb-10 p-8 rounded-2xl text-white shadow-xl relative overflow-hidden"
     style="background: linear-gradient(to right, #003ec7, #60a5fa);">
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full"
         style="background:rgba(255,255,255,0.1); margin-top:-2.5rem; margin-right:-2.5rem; filter:blur(64px);"></div>
    <div class="relative z-10">
        <h1 class="text-3xl font-bold mb-4" style="font-size:2.25rem; letter-spacing:-0.025em;">Face Recognition API</h1>
        <p class="text-base leading-relaxed" style="color:rgb(239 246 255); opacity:0.9; font-size:1.125rem; line-height:1.75;">
            Secure Identity System with Attendance Tracking. Power your organization with industry-leading biometric intelligence and real-time processing.
        </p>
    </div>
</div>

<!-- Dashboard Grid -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-6">

    <!-- ── Live Status Card ── -->
    <div class="md:col-span-4 dashboard-card p-6 flex flex-col justify-between">
        <div>
            <div class="flex items-center justify-between mb-6">
                <h3 class="font-semibold text-lg" style="color:#131b2e;">Live Status</h3>
                <div class="flex items-center gap-2">
                    <span class="h-2 w-2 rounded-full animate-pulse" style="background:#22c55e;"></span>
                    <span class="text-xs font-medium uppercase" style="color:#16a34a; letter-spacing:0.05em;">Live</span>
                </div>
            </div>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-500">group</span>
                        <span class="font-medium" style="color:#434656;">Registered Users</span>
                    </div>
                    <span id="statTotalUsers" class="text-xl font-bold skeleton w-12 h-7" style="color:#003ec7;"></span>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-500">how_to_reg</span>
                        <span class="font-medium" style="color:#434656;">Scans Today</span>
                    </div>
                    <span id="statScansToday" class="text-xl font-bold skeleton w-12 h-7" style="color:#003ec7;"></span>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-500">event_available</span>
                        <span class="font-medium" style="color:#434656;">Present Today</span>
                    </div>
                    <span id="statPresentToday" class="text-xl font-bold skeleton w-12 h-7" style="color:#003ec7;"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── System Overview Card ── -->
    <div class="md:col-span-8 dashboard-card p-6">
        <h3 class="font-semibold text-lg mb-6" style="color:#131b2e;">System Overview</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="p-4 border border-blue-50 rounded-xl" style="background:linear-gradient(to bottom right,#fff,rgba(239,246,255,0.3));">
                <div class="text-sm text-slate-500 font-medium mb-1">Total Records</div>
                <div id="statTotalRecords" class="text-3xl font-bold skeleton h-9 w-16" style="color:#003ec7;"></div>
                <div class="text-xs text-slate-400 font-medium mt-1">All time scans</div>
            </div>
            <div class="p-4 border border-blue-50 rounded-xl" style="background:linear-gradient(to bottom right,#fff,rgba(239,246,255,0.3));">
                <div class="text-sm text-slate-500 font-medium mb-1">This Week</div>
                <div id="statWeekScans" class="text-3xl font-bold skeleton h-9 w-16" style="color:#003ec7;"></div>
                <div class="text-xs text-slate-400 font-medium mt-1">Attendance events</div>
            </div>
            <div class="p-4 border border-blue-50 rounded-xl" style="background:linear-gradient(to bottom right,#fff,rgba(239,246,255,0.3));">
                <div class="text-sm text-slate-500 font-medium mb-1">Avg Hours/Day</div>
                <div id="statAvgHours" class="text-3xl font-bold skeleton h-9 w-16" style="color:#003ec7;"></div>
                <div class="text-xs text-slate-400 font-medium mt-1">Working hours</div>
            </div>
            <div class="p-4 border border-blue-50 rounded-xl" style="background:linear-gradient(to bottom right,#fff,rgba(239,246,255,0.3));">
                <div class="text-sm text-slate-500 font-medium mb-1">Monitoring</div>
                <div class="text-3xl font-bold" style="color:#003ec7;">24/7</div>
                <div class="text-xs text-blue-600 font-medium mt-1">Fully automated</div>
            </div>
        </div>
    </div>

    <!-- ── Chart: Daily Attendance (7-day bar) ── -->
    <div class="md:col-span-8 dashboard-card p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-lg" style="color:#131b2e;">Daily Attendance — Last 7 Days</h3>
            <span class="text-xs text-slate-400 font-medium" id="chartAttendanceRange"></span>
        </div>
        <div style="height:220px;">
            <canvas id="chartAttendance"></canvas>
        </div>
    </div>

    <!-- ── Chart: Hourly Scan Heatmap (line) ── -->
    <div class="md:col-span-4 dashboard-card p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-lg" style="color:#131b2e;">Scans by Hour (Today)</h3>
            <span class="text-xs text-slate-400 font-medium">Today</span>
        </div>
        <div style="height:220px;">
            <canvas id="chartHourly"></canvas>
        </div>
    </div>

    <!-- ── Recent Activity Logs (live) ── -->
    <div class="md:col-span-6 dashboard-card p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-lg" style="color:#131b2e;">Recent Activity Logs</h3>
            <a href="/AttendanceList" class="text-xs font-semibold hover:underline" style="color:#003ec7;">View All</a>
        </div>
        <div id="activityLogs" class="space-y-3">
            <!-- Skeleton rows -->
            <div class="flex items-center gap-3 p-3 border-b border-slate-50">
                <div class="skeleton w-8 h-8 rounded-full shrink-0"></div>
                <div class="flex-1 space-y-1">
                    <div class="skeleton h-3 w-32"></div>
                    <div class="skeleton h-3 w-24"></div>
                </div>
                <div class="skeleton h-3 w-16"></div>
            </div>
            <div class="flex items-center gap-3 p-3 border-b border-slate-50">
                <div class="skeleton w-8 h-8 rounded-full shrink-0"></div>
                <div class="flex-1 space-y-1">
                    <div class="skeleton h-3 w-28"></div>
                    <div class="skeleton h-3 w-20"></div>
                </div>
                <div class="skeleton h-3 w-16"></div>
            </div>
            <div class="flex items-center gap-3 p-3">
                <div class="skeleton w-8 h-8 rounded-full shrink-0"></div>
                <div class="flex-1 space-y-1">
                    <div class="skeleton h-3 w-36"></div>
                    <div class="skeleton h-3 w-24"></div>
                </div>
                <div class="skeleton h-3 w-14"></div>
            </div>
        </div>
    </div>

    <!-- ── Top Users by Hours (live) ── -->
    <div class="md:col-span-6 dashboard-card p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-lg" style="color:#131b2e;">Top Users This Week</h3>
            <a href="/UserWorkingHoursList" class="text-xs font-semibold hover:underline" style="color:#003ec7;">View All</a>
        </div>
        <div id="topUsers" class="space-y-3">
            <div class="skeleton h-8 w-full rounded-xl"></div>
            <div class="skeleton h-8 w-full rounded-xl"></div>
            <div class="skeleton h-8 w-full rounded-xl"></div>
            <div class="skeleton h-8 w-4/5 rounded-xl"></div>
            <div class="skeleton h-8 w-3/5 rounded-xl"></div>
        </div>
    </div>

</div><!-- /grid -->
@section Scripts {
    <script>
        // ── Chart colour palette ──
        const BLUE_GRADIENT_START = 'rgba(0, 62, 199, 0.85)';
        const BLUE_GRADIENT_MID   = 'rgba(0, 82, 255, 0.55)';
        const BLUE_GRADIENT_END   = 'rgba(96, 165, 250, 0.15)';
        const BLUE_LINE           = '#003ec7';
        const BLUE_LIGHT          = '#60a5fa';

        Chart.defaults.font.family = 'Inter, sans-serif';
        Chart.defaults.color = '#737688';

        // ── Data loading ──
        async function loadDashboard() {
        try {
        const today = new Date().toISOString().split('T')[0];

        const [attendanceRes, usersRes, hoursRes] = await Promise.all([
        fetch('/api/attendance'),
        fetch('/api/users'),
        fetch('/api/workinghours')
        ]);

        const attendance = attendanceRes.ok ? await attendanceRes.json() : [];
        const users      = usersRes.ok      ? await usersRes.json()      : [];
        const hoursData  = hoursRes.ok       ? await hoursRes.json()      : [];

        const todayRecords = attendance.filter(r =>
        (r.scanTime || r.timestamp || r.date || '').startsWith(today)
        );
        const uniqueToday = new Set(todayRecords.map(r => r.userId || r.user_id || r.id)).size;

        const weekStart = new Date();
        weekStart.setDate(weekStart.getDate() - weekStart.getDay());
        weekStart.setHours(0, 0, 0, 0);
        const weekRecords = attendance.filter(r =>
        new Date(r.scanTime || r.timestamp || r.date || 0) >= weekStart
        );

        let avgHoursDisplay = '—';
        if (Array.isArray(hoursData) && hoursData.length > 0) {
        const totalSecs = hoursData.reduce((s, r) => s + (r.totalSeconds || r.totalHours * 3600 || 0), 0);
        const avgSecs   = totalSecs / hoursData.length;
        const h = Math.floor(avgSecs / 3600);
        const m = Math.floor((avgSecs % 3600) / 60);
        avgHoursDisplay = `${h}.${String(m).padStart(2, '0')}h`;
        }

        setText('statTotalUsers',   users.length || '—');
        setText('statScansToday',   todayRecords.length || '0');
        setText('statPresentToday', uniqueToday || '0');
        setText('statTotalRecords', attendance.length || '—');
        setText('statWeekScans',    weekRecords.length || '0');
        setText('statAvgHours',     avgHoursDisplay);

        document.getElementById('lastRefresh').textContent =
        'Updated ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        renderActivityLogs(attendance);
        renderTopUsers(hoursData, users);
        renderAttendanceChart(attendance);
        renderHourlyChart(todayRecords);

        } catch (err) {
        console.error('Dashboard load error:', err);
        document.getElementById('lastRefresh').textContent = 'Error loading data';
        }
        }

        // ── Recent Activity Logs ──
        function renderActivityLogs(attendance) {
        const container = document.getElementById('activityLogs');
        const recent = [...attendance]
        .sort((a, b) => new Date(b.scanTime || b.timestamp || 0) - new Date(a.scanTime || a.timestamp || 0))
        .slice(0, 5);

        if (!recent.length) {
        container.innerHTML = '<p class="text-sm text-slate-400 text-center py-4">No recent activity</p>';
        return;
        }

        container.innerHTML = recent.map((r, i) => {
        const isLast   = i === recent.length - 1;
        const name     = r.userName || r.name || r.userId || 'Unknown User';
        const location = r.location || r.terminal || r.device || 'Terminal';
        const time     = timeAgo(r.scanTime || r.timestamp || new Date());
        const type     = (r.type || r.status || 'scan').toLowerCase();

        let iconBg = 'bg-blue-50', iconColor = '#2563eb', icon = 'fingerprint';
        if (type.includes('check_in') || type.includes('enter') || type.includes('in')) {
        iconBg = 'bg-green-50'; iconColor = '#16a34a'; icon = 'login';
        } else if (type.includes('check_out') || type.includes('exit') || type.includes('out')) {
        iconBg = 'bg-indigo-50'; iconColor = '#4f46e5'; icon = 'logout';
        } else if (type.includes('deny') || type.includes('fail')) {
        iconBg = 'bg-amber-50'; iconColor = '#d97706'; icon = 'warning';
        }

        return `
        <div class="flex items-center justify-between p-3 ${isLast ? '' : 'border-b border-slate-50'}">
        <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full ${iconBg} flex items-center justify-center shrink-0" style="color:${iconColor};">
        <span class="material-symbols-outlined" style="font-size:1.125rem;">${icon}</span>
        </div>
        <div>
        <p class="text-sm font-medium" style="color:#131b2e;">${name}</p>
        <p class="text-xs text-slate-400">${location} &bull; ${time}</p>
        </div>
        </div>
        <span class="text-xs font-medium text-slate-500">${type.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}</span>
        </div>`;
        }).join('');
        }

        // ── Top Users by Working Hours ──
        function renderTopUsers(hoursData, users) {
        const container = document.getElementById('topUsers');
        if (!hoursData.length) {
        container.innerHTML = '<p class="text-sm text-slate-400 text-center py-4">No working hours data</p>';
        return;
        }

        const byUser = {};
        hoursData.forEach(r => {
        const uid  = r.userId || r.user_id || r.name || 'Unknown';
        const secs = r.totalSeconds || (r.totalHours || 0) * 3600 || 0;
        byUser[uid] = (byUser[uid] || 0) + secs;
        });

        const sorted  = Object.entries(byUser).sort((a, b) => b[1] - a[1]).slice(0, 5);
        const maxSecs = sorted[0]?.[1] || 1;
        const userMap = {};
        (users || []).forEach(u => { userMap[u.id || u.userId] = u.name || u.username || u.displayName; });

        container.innerHTML = sorted.map(([uid, secs]) => {
        const pct  = Math.round((secs / maxSecs) * 100);
        const name = userMap[uid] || uid;
        const hrs  = formatHours(secs);
        return `
        <div class="space-y-1">
        <div class="flex justify-between text-sm">
        <span class="font-medium truncate max-w-[160px]" style="color:#434656;" title="${name}">${name}</span>
        <span class="text-xs font-semibold" style="color:#003ec7;">${hrs}</span>
        </div>
        <div class="h-2 w-full bg-blue-50 rounded-full overflow-hidden">
        <div class="h-full rounded-full transition-all duration-700"
        style="width:${pct}%; background:linear-gradient(to right,#003ec7,#60a5fa);"></div>
        </div>
        </div>`;
        }).join('');
        }

        // ── Chart: Daily Attendance (7-day bar) ──
        function renderAttendanceChart(attendance) {
        const days = [], labels = [];
        for (let i = 6; i >= 0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        days.push(d.toISOString().split('T')[0]);
        labels.push(d.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' }));
        }
        const counts = days.map(day =>
        attendance.filter(r => (r.scanTime || r.timestamp || r.date || '').startsWith(day)).length
        );
        document.getElementById('chartAttendanceRange').textContent = labels[0] + ' – ' + labels[6];

        const ctx = document.getElementById('chartAttendance').getContext('2d');
        const grad = ctx.createLinearGradient(0, 0, 0, 220);
        grad.addColorStop(0,   BLUE_GRADIENT_START);
        grad.addColorStop(0.6, BLUE_GRADIENT_MID);
        grad.addColorStop(1,   BLUE_GRADIENT_END);

        new Chart(ctx, {
        type: 'bar',
        data: { labels, datasets: [{ label: 'Attendance Events', data: counts, backgroundColor: grad, borderColor: BLUE_LINE, borderWidth: 1.5, borderRadius: 6, borderSkipped: false }] },
        options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { backgroundColor: '#003ec7', titleColor: '#fff', bodyColor: '#dde1ff', callbacks: { label: ctx => ` ${ctx.parsed.y} scan${ctx.parsed.y !== 1 ? 's' : ''}` } } },
        scales: { x: { grid: { display: false }, ticks: { font: { size: 11 } } }, y: { beginAtZero: true, grid: { color: 'rgba(195,197,217,0.3)' }, ticks: { stepSize: 1, font: { size: 11 } } } }
        }
        });
        }

        // ── Chart: Hourly scan distribution (line) ──
        function renderHourlyChart(todayRecords) {
        const hourCounts = Array(24).fill(0);
        todayRecords.forEach(r => {
        const d = new Date(r.scanTime || r.timestamp || 0);
        if (!isNaN(d)) hourCounts[d.getHours()]++;
        });
        const labels = Array.from({ length: 24 }, (_, i) => { const h = i % 12 || 12; return `${h}${i < 12 ? 'am' : 'pm'}`; });

        const ctx = document.getElementById('chartHourly').getContext('2d');
        const areaGrad = ctx.createLinearGradient(0, 0, 0, 220);
        areaGrad.addColorStop(0, 'rgba(0,62,199,0.3)');
        areaGrad.addColorStop(1, 'rgba(0,62,199,0)');

        new Chart(ctx, {
        type: 'line',
        data: { labels, datasets: [{ label: 'Scans', data: hourCounts, borderColor: BLUE_LINE, backgroundColor: areaGrad, borderWidth: 2, pointRadius: 3, pointBackgroundColor: BLUE_LINE, pointHoverRadius: 5, tension: 0.4, fill: true }] },
        options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { backgroundColor: '#003ec7', titleColor: '#fff', bodyColor: '#dde1ff', callbacks: { label: ctx => ` ${ctx.parsed.y} scan${ctx.parsed.y !== 1 ? 's' : ''}` } } },
        scales: { x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 10 } } }, y: { beginAtZero: true, grid: { color: 'rgba(195,197,217,0.3)' }, ticks: { stepSize: 1, font: { size: 10 } } } }
        }
        });
        }

        // ── Boot ──
        document.addEventListener('DOMContentLoaded', () => {
        loadDashboard();
        setInterval(loadDashboard, 60_000);
        });
    </script>
}
