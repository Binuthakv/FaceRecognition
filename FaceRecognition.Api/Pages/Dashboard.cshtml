@page
@model FaceRecognitionApp.Api.Pages.DashboardModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Face Recognition API</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            color: #333;
        }

        .navbar {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }

        .navbar-brand {
            font-size: 20px;
            font-weight: 600;
            color: #667eea;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-nav {
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .navbar-nav a {
            color: #666;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }

        .navbar-nav a:hover {
            color: #667eea;
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #667eea;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .logout-btn {
            padding: 8px 16px;
            background-color: #dc3545;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: background-color 0.3s;
            font-family: inherit;
        }

        .logout-btn:hover {
            background-color: #c82333;
        }

        .logout-form {
            display: inline;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .header {
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 32px;
            color: #333;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 16px;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .card {
            background: white;
            border-radius: 8px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            transform: translateY(-4px);
        }

        .card-icon {
            font-size: 32px;
            margin-bottom: 12px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }

        .card-value {
            font-size: 28px;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 12px;
        }

        .card-text {
            color: #666;
            font-size: 14px;
        }

        .card-link {
            display: inline-block;
            margin-top: 12px;
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .card-link:hover {
            color: #5568d3;
        }

        .quick-links {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .quick-link {
            padding: 16px;
            background: #f5f7fa;
            border-radius: 6px;
            text-decoration: none;
            color: #333;
            border-left: 4px solid #667eea;
            transition: all 0.3s;
        }

        .quick-link:hover {
            background: #667eea;
            color: white;
        }

        .quick-link-title {
            font-weight: 600;
            margin-bottom: 4px;
        }

        .quick-link-desc {
            font-size: 12px;
            opacity: 0.7;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        @@media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                height: auto;
                padding: 12px 20px;
            }

            .navbar-nav {
                gap: 16px;
                flex-wrap: wrap;
            }

            .header h1 {
                font-size: 24px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <div class="navbar">
        <div class="navbar-brand">
            📊 Face Recognition Admin
        </div>
        <div class="navbar-nav">
            <a href="/Dashboard">Dashboard</a>
            <a href="/UserWorkingHoursList">Working Hours</a>
            <a href="/AttendanceList">Attendance</a>
        </div>
        <div class="user-menu">
            <div class="user-avatar">
                @(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value?.FirstOrDefault() ?? 'A')
            </div>
            <form method="post" asp-page-handler="Logout" id="logoutForm" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn" id="logoutBtn">Logout</button>
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>👋 Welcome, @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value!</h1>
            <p>Here's what's happening in your system today.</p>
        </div>

        <!-- Dashboard Cards -->
        <div class="dashboard-grid">
            <!-- Total Users Card -->
            <div class="card">
                <div class="card-icon">👥</div>
                <div class="card-title">Total Users</div>
                <div class="card-value">@Model.TotalUsers</div>
                <div class="card-text">Registered face recognition users</div>
            </div>

            <!-- Today's Attendance Card -->
            <div class="card">
                <div class="card-icon">📅</div>
                <div class="card-title">Working Hours</div>
                <div class="card-value">@Model.TodayAttendance</div>
                <div class="card-text">User Working Hours List</div>
                <a href="/UserWorkingHoursList" class="card-link">View Details →</a>
            </div>

            <!-- Pending Registrations Card -->
            <div class="card">
                <div class="card-icon">⏳</div>
                <div class="card-title">Attendance records</div>
                <div class="card-value">@Model.ThisWeekAttendance</div>
                <div class="card-text">Attendance records </div>
                <a href="/AttendanceList" class="card-link">View Details →</a>
            </div>          
        </div>    

    </div>

    <script>
        // Debug logout form submission
        console.log('Dashboard script loaded');

        document.addEventListener('DOMContentLoaded', function() {
            console.log('Dashboard DOM Content Loaded');
            var logoutForm = document.getElementById('logoutForm');
            var logoutBtn = document.getElementById('logoutBtn');

            console.log('Logout form element:', logoutForm);
            console.log('Logout button element:', logoutBtn);

            if (logoutBtn) {
                logoutBtn.addEventListener('click', function(e) {
                    console.log('Logout button clicked');
                    // Allow default form submission
                    if (logoutForm) {
                        logoutForm.submit();
                    }
                });
            }

            if (logoutForm) {
                logoutForm.addEventListener('submit', function(e) {
                    console.log('Logout form submit event triggered');
                    // Allow form to submit normally
                });
            }
        });
    </script>
</body>
</html>
