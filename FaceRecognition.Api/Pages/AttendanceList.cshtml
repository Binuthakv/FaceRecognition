@page
@model FaceRecognitionApp.Api.Pages.AttendanceListModel
@{
    ViewData["Title"] = "AVIVANEXT | Attendance";
    ViewData["PageLabel"] = "Attendance Records";
    ViewData["ActiveNav"] = "attendance";
    ViewData["LogoutPage"] = "/Dashboard";
    Layout = "~/Pages/Shared/_AppLayout.cshtml";

    var totalRecords = Model.AttendanceRecords.Count;
    var processedCount = Model.AttendanceRecords.Count(r => r.Processed);
    var unprocessedCount = totalRecords - processedCount;
}

<!-- Page Header -->
<div class="mb-12 flex flex-col gap-1">
    <h1 class="font-semibold" style="font-size:32px; line-height:1.2; letter-spacing:-0.01em; color:#131b2e;">Attendance Records</h1>
    <p style="color:#737688;">View all attendance records captured by the Face Recognition System</p>
</div>

<!-- Alert Messages -->
@* @if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert-status-green mb-6 flex items-center gap-3 px-4 py-3 rounded-xl">
        <span class="material-symbols-outlined" style="font-size:20px;">check_circle</span>
        <span class="text-sm font-medium">@Model.StatusMessage</span>
    </div>
} *@
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert-status-red mb-6 flex items-center gap-3 px-4 py-3 rounded-xl">
        <span class="material-symbols-outlined" style="font-size:20px;">error</span>
        <span class="text-sm font-medium">@Model.ErrorMessage</span>
    </div>
}

<!-- Statistics Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <!-- Total Records -->
    <div class="glass-card p-6 rounded-xl" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05); border-top:2px solid #00ccf9;">
        <div class="flex items-center justify-between mb-3">
            <span class="material-symbols-outlined" style="color:#003ec7;">analytics</span>
            <span class="text-xs font-medium px-2 py-1 rounded-full badge-primary">Overall</span>
        </div>
        <div class="flex flex-col">
            <span class="text-2xl font-semibold" style="color:#003ec7;">@totalRecords</span>
            <span class="text-sm" style="color:#737688;">Total Records</span>
        </div>
    </div>
    <!-- Processed -->
    <div class="glass-card p-6 rounded-xl" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05); border-top:2px solid #003ec7;">
        <div class="flex items-center justify-between mb-3">
            <span class="material-symbols-outlined" style="color:#00677f;">check_circle</span>
            <span class="text-xs font-medium px-2 py-1 rounded-full badge-primary">Successful</span>
        </div>
        <div class="flex flex-col">
            <span class="text-2xl font-semibold" style="color:#00677f;">@processedCount</span>
            <span class="text-sm" style="color:#737688;">Processed</span>
        </div>
    </div>
    <!-- Unprocessed -->
    <div class="glass-card p-6 rounded-xl" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05); border-top:2px solid #ba1a1a;">
        <div class="flex items-center justify-between mb-3">
            <span class="material-symbols-outlined" style="color:#ba1a1a;">error</span>
            <span class="text-xs font-medium px-2 py-1 rounded-full badge-primary">Pending</span>
        </div>
        <div class="flex flex-col">
            <span class="text-2xl font-semibold" style="color:#ba1a1a;">@unprocessedCount</span>
            <span class="text-sm" style="color:#737688;">Unprocessed</span>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="glass-card rounded-xl overflow-hidden" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">
    <!-- Table Header / Controls -->
    <div class="table-controls-bar px-6 py-4 border-b flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="flex items-center gap-3">
            <h3 class="font-semibold" style="color:#131b2e; font-size:18px;">Recent Activity</h3>
            <button onclick="location.reload()"
                    class="flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-medium transition-all"
                    style="background:#eaedff; color:#003ec7;">
                <span class="material-symbols-outlined" style="font-size:16px;">refresh</span>
                Refresh
            </button>
        </div>
        <div class="relative w-full sm:w-auto">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2" style="font-size:20px; color:#737688;">search</span>
            <input type="text"
                   placeholder="Search ID or Name..."
                   class="w-full pl-10 pr-4 py-2 rounded-lg outline-none text-sm form-input"
                   oninput="filterTable(this.value)" />
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        @if (Model.PaginatedRecords.Any())
        {
            <table class="w-full text-left" id="attendanceTable">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">Name</th>
                        <th class="px-6 py-4 font-medium">Scan Time</th>
                        <th class="px-6 py-4 font-medium">Status</th>
                    </tr>
                </thead>
                <tbody id="tableBody" style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.PaginatedRecords)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.Name</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.ScanTimeFormatted</td>
                            <td class="px-6 py-4">
                                @if (record.Processed)
                                {
                                    <span class="badge-processed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#16a34a;"></span>
                                        Processed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-unprocessed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#f59e0b;"></span>
                                        Unprocessed
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-16" style="color:#737688;">
                <span class="material-symbols-outlined" style="font-size:48px; color:#c3c5d9; display:block; margin-bottom:12px;">inbox</span>
                <h3 class="font-semibold mb-1" style="color:#434656;">No Attendance Records Found</h3>
                <p class="text-sm">There are currently no attendance records to display.</p>
            </div>
        }
    </div>

    <!-- Table Footer with Pagination -->
    <div class="table-footer-bar px-6 py-4 border-t flex flex-col sm:flex-row justify-between items-center gap-4">
        <span class="text-xs font-medium" style="color:#737688;">
            @if (Model.TotalRecords > 0)
            {
                <text>Showing @((Model.PageNumber - 1) * 10 + 1) to @Math.Min(Model.PageNumber * 10, Model.TotalRecords) of @Model.TotalRecords entries</text>
            }
            else
            {
                <text>No entries</text>
            }
        </span>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center gap-2">
                <!-- Previous Page -->
                @if (Model.PageNumber > 1)
                {
                    <a href="?pageNumber=@(Model.PageNumber - 1)"
                       class="px-3 py-1 rounded-lg text-sm font-medium transition-all"
                       style="background:#eaedff; color:#003ec7; border:1px solid #c3c5d9;">
                        <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle;">chevron_left</span>
                    </a>
                }
                else
                {
                    <button disabled
                            class="px-3 py-1 rounded-lg text-sm font-medium"
                            style="background:#f0f0f0; color:#c3c5d9; border:1px solid #e0e0e0; cursor:not-allowed;">
                        <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle;">chevron_left</span>
                    </button>
                }

                <!-- Page Numbers -->
                <div class="flex items-center gap-1">
                    @{
                        int startPage = Math.Max(1, Model.PageNumber - 2);
                        int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

                        if (startPage > 1)
                        {
                            <a href="?pageNumber=1"
                               class="px-2 py-1 rounded-lg text-xs font-medium transition-all"
                               style="background:#fff; color:#003ec7; border:1px solid #c3c5d9;">1</a>
                            if (startPage > 2)
                            {
                                <span style="color:#737688;">...</span>
                            }
                        }

                        for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <span class="px-2 py-1 rounded-lg text-xs font-medium"
                                      style="background:#003ec7; color:#fff;">@i</span>
                            }
                            else
                            {
                                <a href="?pageNumber=@i"
                                   class="px-2 py-1 rounded-lg text-xs font-medium transition-all"
                                   style="background:#fff; color:#003ec7; border:1px solid #c3c5d9;">@i</a>
                            }
                        }

                        if (endPage < Model.TotalPages)
                        {
                            if (endPage < Model.TotalPages - 1)
                            {
                                <span style="color:#737688;">...</span>
                            }
                            <a href="?pageNumber=@Model.TotalPages"
                               class="px-2 py-1 rounded-lg text-xs font-medium transition-all"
                               style="background:#fff; color:#003ec7; border:1px solid #c3c5d9;">@Model.TotalPages</a>
                        }
                    }
                </div>

                <!-- Next Page -->
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a href="?pageNumber=@(Model.PageNumber + 1)"
                       class="px-3 py-1 rounded-lg text-sm font-medium transition-all"
                       style="background:#eaedff; color:#003ec7; border:1px solid #c3c5d9;">
                        <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle;">chevron_right</span>
                    </a>
                }
                else
                {
                    <button disabled
                            class="px-3 py-1 rounded-lg text-sm font-medium"
                            style="background:#f0f0f0; color:#c3c5d9; border:1px solid #e0e0e0; cursor:not-allowed;">
                        <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle;">chevron_right</span>
                    </button>
                }
            </div>
        }
    </div>
</div>
