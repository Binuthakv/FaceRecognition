@* Pages/Shared/_AppLayout.cshtml
   Used by: Dashboard.cshtml, AttendanceList.cshtml, UserWorkingHoursList.cshtml

   Required ViewData keys the consuming page must set:
     ViewData["Title"]          — window title
     ViewData["PageLabel"]      — top-bar uppercase label (e.g. "System Dashboard")
     ViewData["ActiveNav"]      — "dashboard" | "attendance" | "analysis"
     ViewData["ActiveNavMobile"]— same values (can be same variable)
     ViewData["LogoutPage"]     — asp-page value for the logout POST form

   Optional ViewData:
     ViewData["ShowRefreshBadge"] — any truthy value shows the live-refresh badge
*@

@{
    var displayName = User.Identity?.Name ?? "Admin";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Admin";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
    var initials = string.Concat(
                          displayName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
                                     .Take(2).Select(w => char.ToUpper(w[0])));
    if (string.IsNullOrEmpty(initials)) initials = "A";

    var activeNav = (ViewData["ActiveNav"] as string ?? "").ToLower();
    var logoutPage = ViewData["LogoutPage"] as string ?? "Dashboard";
    var pageLabel = ViewData["PageLabel"] as string ?? "";
    var showRefresh = ViewData["ShowRefreshBadge"] != null;

    // Helpers for sidebar active class
    string NavCls(string key) =>
        activeNav == key ? "nav-link-active flex items-center gap-3 px-4 py-3 rounded-lg font-medium"
                         : "nav-link flex items-center gap-3 px-4 py-3 rounded-lg font-medium";

    string MobileNavCls(string key) =>
        activeNav == key ? "mobile-nav-link mobile-nav-link-active" : "mobile-nav-link";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@@100..700,0..1&display=swap" rel="stylesheet" />

    @RenderSection("CdnHead", required: false)

    <script id="tailwind-config">
        @await Html.PartialAsync("_TailwindConfig")
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("HeadExtra", required: false)
</head>
<body class="text-on-surface" style="color:#131b2e;">

    <!-- ══════════════════════════════════════════
         Top App Bar
         ══════════════════════════════════════════ -->
    <header class="app-header border-b sticky top-0 z-40 h-14 sm:h-16 flex items-center">
        <div class="flex justify-between items-center w-full px-3 sm:px-6 gap-2 sm:gap-4">

            <!-- Left: page label -->
            <div class="topbar-label shrink-0 truncate max-w-[120px] xs:max-w-none">@pageLabel</div>

            <!-- Right: optional refresh badge + user chip + logout -->
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">

                @if (showRefresh)
                {
                    <!-- Live refresh badge -->
                    <div class="hidden sm:flex items-center gap-2 text-xs text-slate-400 shrink-0">
                        <span class="h-2 w-2 rounded-full animate-pulse" style="background:#22c55e;"></span>
                        <span id="lastRefresh">Loading…</span>
                    </div>
                    <div class="hidden sm:block h-5 w-px bg-slate-200 shrink-0"></div>
                }

                <!-- User chip -->
                <div class="flex items-center gap-2 min-w-0">
                    <div class="w-8 h-8 rounded-full avatar-circle flex items-center justify-center text-white text-xs font-bold shrink-0 select-none">
                        @initials
                    </div>
                    <div class="hidden sm:flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-semibold truncate max-w-[140px]" style="color:#131b2e;" title="@displayName">@displayName</span>
                        <span class="text-[11px] font-medium" style="color:#737688;">@userRole</span>
                    </div>
                </div>

                <!-- Logout -->
                <form method="post" asp-page="@logoutPage" class="shrink-0">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            title="Sign out"
                            class="btn-logout flex items-center gap-1.5 px-2.5 sm:px-3 py-1.5 rounded-lg text-xs font-semibold transition-all hover:opacity-90 active:scale-95">
                        <span class="material-symbols-outlined" style="font-size:16px; line-height:1;">logout</span>
                        <span class="hidden sm:inline">Logout</span>
                    </button>
                </form>

            </div>
        </div>
    </header>

    <!-- ══════════════════════════════════════════
         Sidebar
         ══════════════════════════════════════════ -->
    <aside class="sidebar w-64 h-screen fixed top-0 bg-white border-r hidden md:flex flex-col z-50"
           style="border-color:rgba(195,197,217,0.3);">
        <!-- Brand -->
        <div class="h-14 sm:h-16 flex flex-col justify-center px-6 border-b" style="border-color:rgba(195,197,217,0.3);">
            <span class="text-xl font-bold sidebar-brand-name">AVIVANEXT</span>
            <span class="sidebar-brand-sub">Face Recognition API</span>
        </div>
        <!-- Nav -->
        <div class="p-4 lg:p-6 overflow-y-auto flex-1">
            <nav class="space-y-1">
                <a class="@NavCls("dashboard")" href="/Dashboard">
                    <span class="material-symbols-outlined">dashboard</span>
                    Dashboard
                </a>
                <a class="@NavCls("attendance")" href="/AttendanceList">
                    <span class="material-symbols-outlined">event_available</span>
                    Attendance
                </a>
                <a class="@NavCls("analysis")" href="/UserWorkingHoursList">
                    <span class="material-symbols-outlined">query_stats</span>
                    Analysis
                </a>
            </nav>
        </div>
    </aside>

    <!-- ══════════════════════════════════════════
         Main Content
         ══════════════════════════════════════════ -->
    <main class="md:ml-64 pt-4 sm:pt-6 lg:pt-8 px-3 sm:px-4 lg:px-6 pb-24 md:pb-8" style="min-height:100vh;">
        <div class="w-full" style="max-width:1200px; margin:0 auto;">
            @RenderBody()
        </div>
    </main>

    <!-- ══════════════════════════════════════════
         Bottom Mobile Navigation
         ══════════════════════════════════════════ -->
    <nav class="mobile-nav md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center h-16 safe-bottom px-2 rounded-t-2xl shadow-lg"
         style="padding-bottom: env(safe-area-inset-bottom, 0px);">
        <a class="@MobileNavCls("dashboard")" href="/Dashboard">
            <span class="material-symbols-outlined" style="font-size:22px;">home</span>
            <span>Home</span>
        </a>
        <a class="@MobileNavCls("attendance")" href="/AttendanceList">
            <span class="material-symbols-outlined" style="font-size:22px;">event_available</span>
            <span>Attendance</span>
        </a>
        <a class="@MobileNavCls("analysis")" href="/UserWorkingHoursList">
            <span class="material-symbols-outlined" style="font-size:22px;">query_stats</span>
            <span>Analysis</span>
        </a>
    </nav>

    <!-- Shared JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
