@page
@model FaceRecognitionApp.Api.Pages.UserWorkingHoursListModel
@{
    ViewData["Title"] = "AVIVANEXT | Working Hours";
    ViewData["PageLabel"] = "User Working Hours";
    ViewData["ActiveNav"] = "analysis";
    ViewData["LogoutPage"] = "/Dashboard";
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<!-- Page Header -->
<div class="mb-12 flex flex-col gap-1">
    <h1 class="font-semibold" style="font-size:32px; line-height:1.2; letter-spacing:-0.01em; color:#131b2e;">User Working Hours</h1>
    <p style="color:#737688;">Review and evaluate user work hour patterns</p>
</div>

<!-- Processing Summary -->
@if (Model.ShowProcessingInfo && Model.ProcessingSummary != null)
{
    <div class="glass-card rounded-xl p-6 mb-8" style="border-left:4px solid #28a745;">
        <div class="flex items-center gap-2 mb-4">
            <span class="material-symbols-outlined" style="color:#28a745; font-variation-settings:'FILL' 1;">check_circle</span>
            <span class="font-semibold" style="color:#28a745;">Working Hours Processing Summary</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm" style="color:#555;">
            <div>
                <span style="color:#28a745; font-weight:600;">@Model.ProcessingSummary.TotalUsersProcessed</span> users processed
            </div>
            <div>
                <span style="color:#ffc107; font-weight:600;">@Model.ProcessingSummary.UsersSkipped</span> users skipped (insufficient records)
            </div>
            @if (Model.ProcessingSummary.ProcessedRecords.Any())
            {
                <div>
                    <span style="color:#17a2b8; font-weight:600;">@Model.ProcessingSummary.ProcessedRecords.Sum(r => r.RecordsProcessed)</span> attendance records processed
                </div>
            }
        </div>
    </div>
}

<!-- Filter Section -->
<div class="flex items-center justify-end gap-2 mb-6" style="flex-wrap:nowrap;">

    <!-- Date & User filters -->
    <form method="get" asp-page="UserWorkingHoursList" class="flex items-center gap-2" style="flex-wrap:nowrap;">
        <input type="date" id="startDate" name="StartDate"
               value="@Model.StartDate?.ToString("yyyy-MM-dd")"
               class="form-input px-3 py-2 rounded-lg text-sm"
               style="width:145px; flex-shrink:0; border:1px solid #c3c5d9;" />

        <input type="date" id="endDate" name="EndDate"
               value="@Model.EndDate?.ToString("yyyy-MM-dd")"
               class="form-input px-3 py-2 rounded-lg text-sm"
               style="width:145px; flex-shrink:0; border:1px solid #c3c5d9;" />

        <div class="relative" style="flex-shrink:0;">
            <select id="filterUserId" name="FilterUserId"
                    class="form-input px-3 py-2 rounded-lg text-sm appearance-none"
                    style="width:150px; border:1px solid #c3c5d9; padding-right:28px;">
                <option value="">-- All Users --</option>
                @foreach (var user in Model.Users)
                {
                    <option value="@user.UserId" selected="@(Model.FilterUserId == user.UserId)">
                        @user.UserName
                    </option>
                }
            </select>
            <span class="material-symbols-outlined absolute right-2 top-2 pointer-events-none"
                  style="color:#737688; font-size:18px;">expand_more</span>
        </div>

        <input type="hidden" name="ViewType" value="@Model.ViewType" />

        <button type="submit"
                class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
                style="background:#003ec7; color:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">search</span>
            Apply
        </button>

        <a href="/UserWorkingHoursList"
               class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
               style="border:1px solid #c3c5d9; color:#434656; background:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">close</span>
            Clear
        </a>
    </form>

    <!-- Divider -->
    <div style="width:1px; height:28px; background:#c3c5d9; flex-shrink:0; margin:0 4px;"></div>

    <!-- View type toggle -->
    <div class="inline-flex p-1 rounded-xl gap-1" style="background:rgba(234,237,255,0.5); border:1px solid rgba(195,197,217,0.3); flex-shrink:0;">
        @foreach (var vt in new[] { "daily", "weekly", "monthly" })
        {
            <form method="get" asp-page="UserWorkingHoursList" style="display:contents;">
                <input type="hidden" name="viewType" value="@vt" />
                <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="filterUserId" value="@Model.FilterUserId" />
                <button type="submit"
                        class="px-4 py-1.5 rounded-lg text-sm font-semibold capitalize"
                        style="@(Model.ViewType == vt ? "background:#003ec7; color:#fff;" : "color:#737688;")">
                    @(char.ToUpper(vt[0]) + vt.Substring(1))
                </button>
            </form>
        }
    </div>

    <!-- Divider -->
    <div style="width:1px; height:28px; background:#c3c5d9; flex-shrink:0; margin:0 4px;"></div>

    <!-- Action icons — pushed to end -->
    <div class="flex items-center gap-1" style="flex-shrink:0;">
        <button class="p-2 rounded-lg" style="color:#737688;">
            <span class="material-symbols-outlined" style="font-size:20px;">download</span>
        </button>
        <button class="p-2 rounded-lg" style="color:#737688;">
            <span class="material-symbols-outlined" style="font-size:20px;">print</span>
        </button>
    </div>

</div>

<!-- Table Card -->
<div class="glass-card rounded-xl overflow-hidden" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">
    <!-- Table Header -->
    <div class="table-controls-bar px-6 py-4 border-b flex items-center gap-3">
        <span class="material-symbols-outlined" style="color:#003ec7;">table_rows</span>
        <h3 class="font-semibold" style="color:#131b2e; font-size:18px;">Records</h3>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        @if (Model.ViewType == "weekly" && Model.WeeklyWorkingHours.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">Week Period</th>
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">User Name</th>
                        <th class="px-6 py-4 font-medium">Total Hours</th>
                        <th class="px-6 py-4 font-medium">Days Worked</th>
                        <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.WeeklyWorkingHours)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4">
                                <span class="badge-primary inline-flex px-2.5 py-1 rounded-full text-xs font-medium">@record.WeekPeriod</span>
                            </td>
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                            <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                            <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (Model.ViewType == "monthly" && Model.MonthlyWorkingHours.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">Month</th>
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">User Name</th>
                        <th class="px-6 py-4 font-medium">Total Hours</th>
                        <th class="px-6 py-4 font-medium">Days Worked</th>
                        <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.MonthlyWorkingHours)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4">
                                <span class="badge-primary inline-flex px-2.5 py-1 rounded-full text-xs font-medium">@record.MonthPeriod</span>
                            </td>
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                            <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                            <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (Model.ViewType == "daily" && Model.WorkingHoursRecords.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">Name</th>
                        <th class="px-6 py-4 font-medium">Date</th>
                        <th class="px-6 py-4 font-medium">Working Hours</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.WorkingHoursRecords)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.Name</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.LoginDateFormatted</td>
                            <td class="px-6 py-4">
                                <span class="badge-processed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#16a34a;"></span>
                                    @record.WorkingHoursFormatted
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-16" style="color:#737688;">
                <span class="material-symbols-outlined" style="font-size:48px; color:#c3c5d9; display:block; margin-bottom:12px;">search_off</span>
                <h3 class="font-semibold mb-1" style="color:#434656;">No Records Found</h3>
                <p class="text-sm">No working hours records match your current filters.</p>
            </div>
        }
    </div>

    <!-- Table Footer -->
    <div class="table-footer-bar px-6 py-4 border-t flex justify-between items-center">
        <span class="text-xs font-medium" style="color:#737688;">
            @{
                var count = Model.ViewType == "weekly" ? Model.WeeklyWorkingHours.Count
                          : Model.ViewType == "monthly" ? Model.MonthlyWorkingHours.Count
                          : Model.WorkingHoursRecords.Count;
            }
            Showing @count entries
        </span>
    </div>
</div>
