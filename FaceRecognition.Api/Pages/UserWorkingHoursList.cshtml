@page
@model FaceRecognitionApp.Api.Pages.UserWorkingHoursListModel
@{
    ViewData["Title"] = "AVIVANEXT | Working Hours";
    ViewData["PageLabel"] = "User Working Hours";
    ViewData["ActiveNav"] = "analysis";
    ViewData["LogoutPage"] = "/Dashboard";
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<!-- Print Stylesheet -->
<style>
    #printSection { display: none; }

    @@media print {
        @@page { size: A4 portrait; margin: 0; }

        body > *:not(.print-clone) { display: none !important; }

        .print-clone {
            display: block !important;
            position: static !important;
            width: 100%;
            background: #fff !important;
            color: #000 !important;
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 11px;
            padding: 14mm 12mm 10mm 12mm;
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .print-clone * { color: #000 !important; background: transparent !important; }

        .ph-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .ph-brand { font-size: 17px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2px; }
        .ph-title { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
        .ph-range { font-size: 10px; }
        .ph-date  { font-size: 10px; font-weight: 600; text-align: right; }

        .pt {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
            margin-bottom: 0;
        }
        .pt th, .pt td {
            border: 1px solid #000;
            padding: 5px 8px;
            text-align: left;
            vertical-align: middle;
        }
        .pt thead th {
            font-weight: 700;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .pt tbody td { font-size: 10px; }

        .pt tfoot td {
            font-weight: 700;
            font-size: 10px;
            border: 1px solid #000;
        }

        .pf {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 5px 12mm;
            border-top: 1px solid #000;
            font-size: 9px;
            display: flex;
            justify-content: space-between;
            background: #fff !important;
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }
</style>

<div id="printSection">
    @{
        var prDateRange = "";
        if (Model.StartDate.HasValue && Model.EndDate.HasValue)
            prDateRange = Model.StartDate.Value.ToString("dd-MM-yyyy") + " - " + Model.EndDate.Value.ToString("dd-MM-yyyy");
        else if (Model.StartDate.HasValue)
            prDateRange = "From " + Model.StartDate.Value.ToString("dd-MM-yyyy");
        else if (Model.EndDate.HasValue)
            prDateRange = "To " + Model.EndDate.Value.ToString("dd-MM-yyyy");
        else
            prDateRange = "All Records";
    }

    <div class="ph-row">
        <div>
            <div class="ph-brand">AVIVANEXT</div>
            <div class="ph-title">User Working Hours</div>
            <div class="ph-range">@prDateRange</div>
        </div>
        <div class="ph-date">@DateTime.Now.ToString("dd-MM-yyyy")</div>
    </div>

    @if (Model.ViewType == "weekly" && Model.WeeklyWorkingHours.Any())
    {
        var wTotalDays  = Model.WeeklyWorkingHours.Sum(r => r.DaysWorked);
        var wTotalMins  = Model.WeeklyWorkingHours.Sum(r => (int)Math.Floor(r.TotalHours) * 60 + (int)Math.Round((r.TotalHours - Math.Floor(r.TotalHours)) * 60));
        var wTotalHDisp = $"{wTotalMins / 60}h {wTotalMins % 60}m";
        <table class="pt">
            <thead>
                <tr>
                    <th>Week Period</th>
                    <th>User ID</th>
                    <th>User Name</th>
                    <th>Total Hours</th>
                    <th>Days Worked</th>
                    <th>Avg Hours / Day</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.WeeklyWorkingHours)
                {
                    <tr>
                        <td>@r.WeekPeriod</td>
                        <td>@r.UserId</td>
                        <td>@r.UserName</td>
                        <td>@r.TotalHoursFormatted</td>
                        <td>@r.DaysWorked days</td>
                        <td>@r.AverageFormatted</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td><strong>Totals</strong></td>
                    <td></td>
                    <td></td>
                    <td><strong>@wTotalHDisp</strong></td>
                    <td><strong>@wTotalDays days</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    }
    else if (Model.ViewType == "monthly" && Model.MonthlyWorkingHours.Any())
    {
        var mTotalDays  = Model.MonthlyWorkingHours.Sum(r => r.DaysWorked);
        var mTotalMins  = Model.MonthlyWorkingHours.Sum(r => (int)Math.Floor(r.TotalHours) * 60 + (int)Math.Round((r.TotalHours - Math.Floor(r.TotalHours)) * 60));
        var mTotalHDisp = $"{mTotalMins / 60}h {mTotalMins % 60}m";
        <table class="pt">
            <thead>
                <tr>
                    <th>Month</th>
                    <th>User ID</th>
                    <th>User Name</th>
                    <th>Total Hours</th>
                    <th>Days Worked</th>
                    <th>Avg Hours / Day</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.MonthlyWorkingHours)
                {
                    <tr>
                        <td>@r.MonthPeriod</td>
                        <td>@r.UserId</td>
                        <td>@r.UserName</td>
                        <td>@r.TotalHoursFormatted</td>
                        <td>@r.DaysWorked days</td>
                        <td>@r.AverageFormatted</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td><strong>Totals</strong></td>
                    <td></td>
                    <td></td>
                    <td><strong>@mTotalHDisp</strong></td>
                    <td><strong>@mTotalDays days</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    }
    else if (Model.ViewType == "daily" && Model.WorkingHoursRecords.Any())
    {
        var dTotalDays  = Model.WorkingHoursRecords.Select(r => r.LoginDateFormatted).Distinct().Count();
        var dTotalMins  = Model.WorkingHoursRecords.Sum(r => (int)Math.Floor(r.WorkingHours) * 60 + (int)Math.Round((r.WorkingHours - Math.Floor(r.WorkingHours)) * 60));
        var dTotalHDisp = $"{dTotalMins / 60}h {dTotalMins % 60}m";
        <table class="pt">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Name</th>
                    <th>Date</th>
                    <th>Working Hours</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.WorkingHoursRecords)
                {
                    <tr>
                        <td>@r.UserId</td>
                        <td>@r.Name</td>
                        <td>@r.LoginDateFormatted</td>
                        <td>@r.WorkingHoursFormatted</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td><strong>Totals</strong></td>
                    <td></td>
                    <td><strong>@dTotalDays days</strong></td>
                    <td><strong>@dTotalHDisp</strong></td>
                </tr>
            </tfoot>
        </table>
    }

    <div class="pf">
        <span>AVIVANEXT Face Recognition System &mdash; Confidential</span>
        <span>Page 1</span>
    </div>
</div>

<script id="whDataIsland" type="application/json">
@{
    var jsonRows = new System.Text.StringBuilder();
    jsonRows.Append("[");

    if (Model.ViewType == "weekly" && Model.WeeklyWorkingHours.Any())
    {
        bool first = true;
        foreach (var r in Model.WeeklyWorkingHours)
        {
            if (!first) jsonRows.Append(",");
            first = false;
            jsonRows.Append("{");
            jsonRows.Append("\"period\":"     + System.Text.Json.JsonSerializer.Serialize(r.WeekPeriod) + ",");
            jsonRows.Append("\"userId\":"     + System.Text.Json.JsonSerializer.Serialize(r.UserId.ToString()) + ",");
            jsonRows.Append("\"userName\":"   + System.Text.Json.JsonSerializer.Serialize(r.UserName) + ",");
            jsonRows.Append("\"totalHours\":" + System.Text.Json.JsonSerializer.Serialize(r.TotalHoursFormatted) + ",");
            jsonRows.Append("\"daysWorked\":" + r.DaysWorked + ",");
            jsonRows.Append("\"avgHours\":"   + System.Text.Json.JsonSerializer.Serialize(r.AverageFormatted));
            jsonRows.Append("}");
        }
    }
    else if (Model.ViewType == "monthly" && Model.MonthlyWorkingHours.Any())
    {
        bool first = true;
        foreach (var r in Model.MonthlyWorkingHours)
        {
            if (!first) jsonRows.Append(",");
            first = false;
            jsonRows.Append("{");
            jsonRows.Append("\"period\":"     + System.Text.Json.JsonSerializer.Serialize(r.MonthPeriod) + ",");
            jsonRows.Append("\"userId\":"     + System.Text.Json.JsonSerializer.Serialize(r.UserId.ToString()) + ",");
            jsonRows.Append("\"userName\":"   + System.Text.Json.JsonSerializer.Serialize(r.UserName) + ",");
            jsonRows.Append("\"totalHours\":" + System.Text.Json.JsonSerializer.Serialize(r.TotalHoursFormatted) + ",");
            jsonRows.Append("\"daysWorked\":" + r.DaysWorked + ",");
            jsonRows.Append("\"avgHours\":"   + System.Text.Json.JsonSerializer.Serialize(r.AverageFormatted));
            jsonRows.Append("}");
        }
    }
    else if (Model.ViewType == "daily" && Model.WorkingHoursRecords.Any())
    {
        bool first = true;
        foreach (var r in Model.WorkingHoursRecords)
        {
            if (!first) jsonRows.Append(",");
            first = false;
            jsonRows.Append("{");
            jsonRows.Append("\"userId\":"       + System.Text.Json.JsonSerializer.Serialize(r.UserId.ToString()) + ",");
            jsonRows.Append("\"userName\":"     + System.Text.Json.JsonSerializer.Serialize(r.Name) + ",");
            jsonRows.Append("\"date\":"         + System.Text.Json.JsonSerializer.Serialize(r.LoginDateFormatted) + ",");
            jsonRows.Append("\"workingHours\":" + System.Text.Json.JsonSerializer.Serialize(r.WorkingHoursFormatted));
            jsonRows.Append("}");
        }
    }

    jsonRows.Append("]");

    var filParts = new System.Collections.Generic.List<string>();
    if (Model.StartDate.HasValue) filParts.Add("From " + Model.StartDate.Value.ToString("dd-MMM-yyyy"));
    if (Model.EndDate.HasValue)   filParts.Add("To "   + Model.EndDate.Value.ToString("dd-MMM-yyyy"));
    if (!string.IsNullOrEmpty(Model.FilterUserId?.ToString()))
    {
        var fu = Model.Users.FirstOrDefault(x => x.UserId == Model.FilterUserId);
        if (fu != null) filParts.Add("User: " + fu.UserName);
    }
    var islandFilterDesc = filParts.Count > 0 ? string.Join(" | ", filParts) : "All Records";

    var islandJson = new System.Text.StringBuilder();
    islandJson.Append("{");
    islandJson.Append("\"viewType\":"   + System.Text.Json.JsonSerializer.Serialize(Model.ViewType) + ",");
    islandJson.Append("\"filterDesc\":" + System.Text.Json.JsonSerializer.Serialize(islandFilterDesc) + ",");
    islandJson.Append("\"startDate\":" + System.Text.Json.JsonSerializer.Serialize(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("dd-MM-yyyy") : "") + ",");
    islandJson.Append("\"endDate\":" + System.Text.Json.JsonSerializer.Serialize(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd-MM-yyyy") : "") + ",");
    islandJson.Append("\"generatedAt\":" + System.Text.Json.JsonSerializer.Serialize(DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")) + ",");
    islandJson.Append("\"rows\":" + jsonRows.ToString());
    islandJson.Append("}");
}
@Html.Raw(islandJson.ToString())
</script>

<div class="mb-12 flex flex-col gap-1">
    <h1 class="font-semibold" style="font-size:32px; line-height:1.2; letter-spacing:-0.01em; color:#131b2e;">User Working Hours</h1>
    <p style="color:#737688;">Review and evaluate user work hour patterns</p>
</div>

<!-- Processing Summary -->
@if (Model.ShowProcessingInfo && Model.ProcessingSummary != null)
{
    <div class="glass-card rounded-xl p-6 mb-8" style="border-left:4px solid #28a745;">
        <div class="flex items-center gap-2 mb-4">
            <span class="material-symbols-outlined" style="color:#28a745; font-variation-settings:'FILL' 1;">check_circle</span>
            <span class="font-semibold" style="color:#28a745;">Working Hours Processing Summary</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm" style="color:#555;">
            <div>
                <span style="color:#28a745; font-weight:600;">@Model.ProcessingSummary.TotalUsersProcessed</span> users processed
            </div>
            <div>
                <span style="color:#ffc107; font-weight:600;">@Model.ProcessingSummary.UsersSkipped</span> users skipped (insufficient records)
            </div>
            @if (Model.ProcessingSummary.ProcessedRecords.Any())
            {
                <div>
                    <span style="color:#17a2b8; font-weight:600;">@Model.ProcessingSummary.ProcessedRecords.Sum(r => r.RecordsProcessed)</span> attendance records processed
                </div>
            }
        </div>
    </div>
}


<div class="flex items-center justify-end gap-2 mb-6" style="flex-wrap:nowrap;">

    <!-- Date & User filters -->
    <form method="get" asp-page="UserWorkingHoursList" class="flex items-center gap-2" style="flex-wrap:nowrap;">
        <input type="date" id="startDate" name="StartDate"
               value="@Model.StartDate?.ToString("yyyy-MM-dd")"
               class="form-input px-3 py-2 rounded-lg text-sm"
               style="width:145px; flex-shrink:0; border:1px solid #c3c5d9;" />

        <input type="date" id="endDate" name="EndDate"
               value="@Model.EndDate?.ToString("yyyy-MM-dd")"
               class="form-input px-3 py-2 rounded-lg text-sm"
               style="width:145px; flex-shrink:0; border:1px solid #c3c5d9;" />

        <div class="relative" style="flex-shrink:0;">
            <select id="filterUserId" name="FilterUserId"
                    class="form-input px-3 py-2 rounded-lg text-sm appearance-none"
                    style="width:150px; border:1px solid #c3c5d9; padding-right:28px;">
                <option value="">-- All Users --</option>
                @foreach (var user in Model.Users)
                {
                    <option value="@user.UserId" selected="@(Model.FilterUserId == user.UserId)">
                        @user.UserName
                    </option>
                }
            </select>
            <span class="material-symbols-outlined absolute right-2 top-2 pointer-events-none"
                  style="color:#737688; font-size:18px;">expand_more</span>
        </div>

        <input type="hidden" name="ViewType" value="@Model.ViewType" />

        <button type="submit"
                class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
                style="background:#003ec7; color:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">search</span>
            Apply
        </button>

        <a href="/UserWorkingHoursList"
               class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
               style="border:1px solid #c3c5d9; color:#434656; background:#fff; flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:15px;">close</span>
            Clear
        </a>
    </form>

    <!-- Divider -->
    <div style="width:1px; height:28px; background:#c3c5d9; flex-shrink:0; margin:0 4px;"></div>

    <!-- View type toggle -->
    <div class="inline-flex p-1 rounded-xl gap-1" style="background:rgba(234,237,255,0.5); border:1px solid rgba(195,197,217,0.3); flex-shrink:0;">
        @foreach (var vt in new[] { "daily", "weekly", "monthly" })
        {
            <form method="get" asp-page="UserWorkingHoursList" style="display:contents;">
                <input type="hidden" name="viewType" value="@vt" />
                <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="filterUserId" value="@Model.FilterUserId" />
                <button type="submit"
                        class="px-4 py-1.5 rounded-lg text-sm font-semibold capitalize"
                        style="@(Model.ViewType == vt ? "background:#003ec7; color:#fff;" : "color:#737688;")">
                    @(char.ToUpper(vt[0]) + vt.Substring(1))
                </button>
            </form>
        }
    </div>

    <!-- Divider -->
    <div style="width:1px; height:28px; background:#c3c5d9; flex-shrink:0; margin:0 4px;"></div>

    <!-- Action icons -->
    <div class="flex items-center gap-1" style="flex-shrink:0;">
        <button id="btnDownload"
                onclick="downloadCSV()"
                title="Download as CSV (Excel)"
                class="p-2 rounded-lg transition-colors"
                style="color:#737688;"
                onmouseover="this.style.background='#eef1ff'; this.style.color='#003ec7';"
                onmouseout="this.style.background=''; this.style.color='#737688';">
            <span class="material-symbols-outlined" style="font-size:20px;">download</span>
        </button>
        <button id="btnPrint"
                onclick="triggerPrint()"
                title="Print this report"
                class="p-2 rounded-lg transition-colors"
                style="color:#737688;"
                onmouseover="this.style.background='#eef1ff'; this.style.color='#003ec7';"
                onmouseout="this.style.background=''; this.style.color='#737688';">
            <span class="material-symbols-outlined" style="font-size:20px;">print</span>
        </button>
    </div>

</div>

<!-- Table Card -->
<div class="glass-card rounded-xl overflow-hidden" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">
    <div class="table-controls-bar px-6 py-4 border-b flex items-center gap-3">
        <span class="material-symbols-outlined" style="color:#003ec7;">table_rows</span>
        <h3 class="font-semibold" style="color:#131b2e; font-size:18px;">Records</h3>
    </div>

    <div class="overflow-x-auto">
        @if (Model.ViewType == "weekly" && Model.WeeklyWorkingHours.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">Week Period</th>
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">User Name</th>
                        <th class="px-6 py-4 font-medium">Total Hours</th>
                        <th class="px-6 py-4 font-medium">Days Worked</th>
                        <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.WeeklyWorkingHours)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4">
                                <span class="badge-primary inline-flex px-2.5 py-1 rounded-full text-xs font-medium">@record.WeekPeriod</span>
                            </td>
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                            <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                            <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (Model.ViewType == "monthly" && Model.MonthlyWorkingHours.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">Month</th>
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">User Name</th>
                        <th class="px-6 py-4 font-medium">Total Hours</th>
                        <th class="px-6 py-4 font-medium">Days Worked</th>
                        <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.MonthlyWorkingHours)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4">
                                <span class="badge-primary inline-flex px-2.5 py-1 rounded-full text-xs font-medium">@record.MonthPeriod</span>
                            </td>
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                            <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                            <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (Model.ViewType == "daily" && Model.WorkingHoursRecords.Any())
        {
            <table class="w-full text-left">
                <thead>
                    <tr class="table-header-row">
                        <th class="px-6 py-4 font-medium">User ID</th>
                        <th class="px-6 py-4 font-medium">Name</th>
                        <th class="px-6 py-4 font-medium">Date</th>
                        <th class="px-6 py-4 font-medium">Working Hours</th>
                    </tr>
                </thead>
                <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                    @foreach (var record in Model.WorkingHoursRecords)
                    {
                        <tr class="table-row">
                            <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                            <td class="px-6 py-4" style="color:#131b2e;">@record.Name</td>
                            <td class="px-6 py-4" style="color:#434656;">@record.LoginDateFormatted</td>
                            <td class="px-6 py-4">
                                <span class="badge-processed inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#16a34a;"></span>
                                    @record.WorkingHoursFormatted
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-16" style="color:#737688;">
                <span class="material-symbols-outlined" style="font-size:48px; color:#c3c5d9; display:block; margin-bottom:12px;">search_off</span>
                <h3 class="font-semibold mb-1" style="color:#434656;">No Records Found</h3>
                <p class="text-sm">No working hours records match your current filters.</p>
            </div>
        }
    </div>

    <div class="table-footer-bar px-6 py-4 border-t flex justify-between items-center">
        <span class="text-xs font-medium" style="color:#737688;">
            @{
                var count = Model.ViewType == "weekly" ? Model.WeeklyWorkingHours.Count
                          : Model.ViewType == "monthly" ? Model.MonthlyWorkingHours.Count
                          : Model.WorkingHoursRecords.Count;
            }
            Showing @count entries
        </span>
    </div>
</div>

<!-- ExcelJS .xlsx download -->
