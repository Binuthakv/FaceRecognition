<!-- JavaScript Download XLSX  &  Print -->
<script>
(function () {

    function getDataIsland() {
        try { return JSON.parse(document.getElementById('whDataIsland').textContent); }
        catch (e) { console.error('Data island parse error:', e); return null; }
    }

    function capitalise(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }

    function parseMins(str) {
        if (!str) return 0;
        var s = String(str).trim();
        var hm = s.match(/^(?:(\d+)h\s*)?(?:(\d+)m)?$/i);
        if (hm && (hm[1] || hm[2]))
            return (parseInt(hm[1] || '0', 10) * 60) + parseInt(hm[2] || '0', 10);
        var num = parseFloat(s);
        return isNaN(num) ? 0 : Math.round(num * 60);
    }

    function formatMins(totalMins) {
        var h = Math.floor(totalMins / 60), m = totalMins % 60;
        return h + 'h ' + (m < 10 ? '0' : '') + m + 'm';
    }

    function headerStyle(wb) {
        return {
            font:      { name: 'Arial', bold: true, size: 10, color: { argb: 'FF131B2E' } },
            fill:      { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFF3CD' } },
            alignment: { horizontal: 'center', vertical: 'middle', wrapText: true },
            border:    {
                top:    { style: 'thin', color: { argb: 'FFFFC107' } },
                bottom: { style: 'thin', color: { argb: 'FFFFC107' } }
            }
        };
    }

    function dataStyle() {
        return {
            font:      { name: 'Arial', size: 10, color: { argb: 'FF131B2E' } },
            alignment: { vertical: 'middle' },
            border:    { bottom: { style: 'hair', color: { argb: 'FFE0E4F0' } } }
        };
    }

    function totalsStyle() {
        return {
            font:      { name: 'Arial', bold: true, size: 10, color: { argb: 'FF131B2E' } },
            fill:      { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFF3CD' } },
            alignment: { horizontal: 'center', vertical: 'middle' },
            border:    {
                top:    { style: 'thin', color: { argb: 'FFFFC107' } },
                bottom: { style: 'thin', color: { argb: 'FFFFC107' } }
            }
        };
    }

    function applyStyle(cell, style) {
        if (style.font)      cell.font      = style.font;
        if (style.fill)      cell.fill      = style.fill;
        if (style.alignment) cell.alignment = style.alignment;
        if (style.border)    cell.border    = style.border;
    }

    function styleRow(row, styleFn) {
        row.eachCell({ includeEmpty: true }, function (cell) {
            applyStyle(cell, styleFn());
        });
        row.height = 22;
    }

    /* XLSX builder  */

    async function buildXLSX(island) {
        var wb   = new ExcelJS.Workbook();
        wb.creator = 'AVIVANEXT';
        var ws   = wb.addWorksheet('Working Hours', { views: [{ state: 'frozen', ySplit: 1 }] });
        var rows = island.rows;

        var cols;
        if (island.viewType === 'daily') {
            cols = [
                { header: 'User ID',       key: 'userId',       width: 16 },
                { header: 'User Name',     key: 'userName',     width: 26 },
                { header: 'Date',          key: 'date',         width: 18 },
                { header: 'Working Hours', key: 'workingHours', width: 18 }
            ];
        } else {
            var periodLabel = island.viewType === 'weekly' ? 'Week Period' : 'Month';
            cols = [
                { header: periodLabel,     key: 'period',     width: 26 },
                { header: 'User ID',       key: 'userId',     width: 16 },
                { header: 'User Name',     key: 'userName',   width: 26 },
                { header: 'Total Hours',   key: 'totalHours', width: 18 },
                { header: 'Days Worked',   key: 'daysWorked', width: 16 },
                { header: 'Avg Hours/Day', key: 'avgHours',   width: 18 }
            ];
        }
        ws.columns = cols;

        var headerRow = ws.getRow(1);
        headerRow.values = cols.map(function (c) { return c.header; });
        styleRow(headerRow, headerStyle);
        headerRow.height = 28;

        rows.forEach(function (r) {
            var values;
            if (island.viewType === 'daily') {
                values = [r.userId, r.userName, r.date, r.workingHours];
            } else {
                values = [r.period, r.userId, r.userName, r.totalHours,
                          typeof r.daysWorked === 'number' ? r.daysWorked + ' days' : r.daysWorked,
                          r.avgHours];
            }
            var dr = ws.addRow(values);
            styleRow(dr, dataStyle);
        });

        var grandMins = rows.reduce(function (acc, r) {
            return acc + parseMins(r.totalHours || r.workingHours);
        }, 0);
        var grandDays = rows.reduce(function (acc, r) {
            return acc + ((typeof r.daysWorked === 'number') ? r.daysWorked : 1);
        }, 0);

        var totalsValues;
        if (island.viewType === 'daily') {
            totalsValues = ['TOTALS', '', '', formatMins(grandMins)];
        } else {
            totalsValues = ['TOTALS', '', '', formatMins(grandMins), grandDays + ' days', ''];
        }
        var tr = ws.addRow(totalsValues);
        styleRow(tr, totalsStyle);

        var buffer = await wb.xlsx.writeBuffer();
        var blob   = new Blob([buffer], {
            type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        });
        var url  = URL.createObjectURL(blob);
        var ts   = new Date().toISOString().slice(0, 10);
        var dateRange = island.startDate && island.endDate ? '_' + island.startDate + '_to_' + island.endDate
                      : island.startDate ? '_from_' + island.startDate
                      : island.endDate   ? '_to_'   + island.endDate : '';
        var name = 'user working hours' + '.xlsx';
        var a    = document.createElement('a');
        a.href = url; a.download = name; a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        setTimeout(function () { document.body.removeChild(a); URL.revokeObjectURL(url); }, 600);
    }

    
    window.downloadCSV = function () {
        var island = getDataIsland();
        if (!island) { alert('No data available to download.'); return; }
        if (!island.rows || island.rows.length === 0) { alert('No records to download for the current filters.'); return; }
        buildXLSX(island).catch(function (err) {
            console.error('XLSX build error:', err);
            alert('Could not generate the Excel file. Please try again.');
        });
    };

    
    window.triggerPrint = function () {
        var ps = document.getElementById('printSection');
        if (!ps) { window.print(); return; }

        var clone = ps.cloneNode(true);
        clone.removeAttribute('id');          
        clone.classList.add('print-clone');   
        clone.style.cssText = '';             
        document.body.appendChild(clone);

        var originalTitle = document.title;
        document.title = 'User_Working_Hours_Report';

        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                window.print();

               var cleanup = function () {
                    document.title = originalTitle;
                    if (clone.parentNode) { clone.parentNode.removeChild(clone); }
                    window.removeEventListener('afterprint', cleanup);
                };
                window.addEventListener('afterprint', cleanup);
                setTimeout(cleanup, 5000);
            });
        });
    };

})();
</script>
