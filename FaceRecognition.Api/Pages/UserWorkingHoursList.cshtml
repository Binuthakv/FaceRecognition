@page
@model FaceRecognitionApp.Api.Pages.UserWorkingHoursListModel
@{
    ViewData["Title"] = "AVIVANEXT | Face Recognition API";
    var displayName = User.Identity?.Name ?? "Admin";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Admin";
    var initials = string.Concat(displayName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
                          .Take(2).Select(w => char.ToUpper(w[0])));
    if (string.IsNullOrEmpty(initials)) initials = "A";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Face Recognition API</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        "on-tertiary-fixed-variant": "#3f4749",
        "surface-tint": "#004ced",
        "secondary-container": "#00ccf9",
        "on-error-container": "#93000a",
        "tertiary-container": "#5e667a",
        "surface-bright": "#faf8ff",
        "tertiary": "#474e61",
        "on-secondary-fixed-variant": "#004e60",
        "inverse-primary": "#b7c4ff",
        "surface": "#faf8ff",
        "secondary-fixed": "#b7eaff",
        "primary": "#003ec7",
        "background": "#faf8ff",
        "surface-dim": "#d2d9f4",
        "tertiary-fixed-dim": "#bfc6dd",
        "on-tertiary-fixed": "#141b2c",
        "on-surface-variant": "#434656",
        "on-secondary": "#ffffff",
        "primary-container": "#0052ff",
        "on-secondary-fixed": "#001f28",
        "inverse-surface": "#283044",
        "primary-fixed": "#dde1ff",
        "on-tertiary-container": "#dde4fc",
        "on-surface": "#131b2e",
        "surface-container-lowest": "#ffffff",
        "on-error": "#ffffff",
        "surface-variant": "#dae2fd",
        "on-background": "#131b2e",
        "tertiary-fixed": "#dbe2fa",
        "primary-fixed-dim": "#b7c4ff",
        "error-container": "#ffdad6",
        "outline": "#737688",
        "surface-container": "#eaedff",
        "inverse-on-surface": "#eef0ff",
        "on-tertiary": "#ffffff",
        "outline-variant": "#c3c5d9",
        "on-primary-container": "#dfe3ff",
        "on-primary": "#ffffff",
        "surface-container-highest": "#dae2fd",
        "secondary-fixed-dim": "#4cd6ff",
        "secondary": "#00677f",
        "error": "#ba1a1a",
        "on-primary-fixed-variant": "#0038b6",
        "on-secondary-container": "#005266",
        "surface-container-low": "#f2f3ff",
        "on-primary-fixed": "#001452",
        "surface-container-high": "#e2e7ff"
        },
        borderRadius: {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
        },
        spacing: {
        "xl": "80px",
        "sm": "12px",
        "md": "24px",
        "margin": "32px",
        "gutter": "24px",
        "xs": "4px",
        "lg": "48px",
        "base": "8px"
        },
        fontFamily: {
        "headline-xl": ["Inter"],
        "label-sm": ["Inter"],
        "headline-lg": ["Inter"],
        "body-lg": ["Inter"],
        "code": ["Inter"],
        "body-md": ["Inter"],
        "headline-md": ["Inter"]
        },
        fontSize: {
        "headline-xl": ["48px", { lineHeight: "1.1", letterSpacing: "-0.02em", fontWeight: "700" }],
        "label-sm": ["14px", { lineHeight: "1", letterSpacing: "0.01em", fontWeight: "500" }],
        "headline-lg": ["32px", { lineHeight: "1.2", letterSpacing: "-0.01em", fontWeight: "600" }],
        "body-lg": ["18px", { lineHeight: "1.6", fontWeight: "400" }],
        "code": ["14px", { lineHeight: "1.5", fontWeight: "400" }],
        "body-md": ["16px", { lineHeight: "1.5", fontWeight: "400" }],
        "headline-md": ["24px", { lineHeight: "1.3", fontWeight: "600" }]
        }
        }
        }
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
        font-family: Inter, sans-serif;
        background-color: #faf8ff;
        min-height: 100dvh;
        }

        .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(218, 226, 253, 0.5);
        }
    </style>
</head>
<body class="text-on-surface" style="color:#131b2e;">

    <!-- Top Bar -->
    <header class="border-b sticky top-0 z-40 h-16 flex items-center"
            style="background:rgba(255,255,255,0.8); backdrop-filter:blur(12px); border-color:rgba(195,197,217,0.3);">
        <div class="flex justify-between items-center w-full px-6 gap-4">

            <!-- Left: page label — change this text per page -->
            <div class="font-bold uppercase shrink-0" style="font-size:11px; letter-spacing:0.2em; color:#737688;">
                PAGE_LABEL
            </div>

            <!-- Right: user chip + logout -->
            <div class="flex items-center gap-3 min-w-0">

                <!-- User chip -->
                <div class="flex items-center gap-2 min-w-0">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 select-none"
                         style="background:linear-gradient(135deg,#003ec7,#60a5fa);">
                        @initials
                    </div>
                    <div class="hidden sm:flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-semibold truncate max-w-[140px]" style="color:#131b2e;" title="@displayName">@displayName</span>
                        <span class="text-[11px] font-medium" style="color:#737688;">@userRole</span>
                    </div>
                </div>

                <!-- Logout — update asp-page to match this page's route -->
                <form method="post" asp-page="AttendanceList" class="shrink-0">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            title="Sign out"
                            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all hover:opacity-90 active:scale-95"
                            style="background:linear-gradient(135deg,#003ec7,#60a5fa); color:#fff;">
                        <span class="material-symbols-outlined" style="font-size:16px; line-height:1;">logout</span>
                        <span class="hidden sm:inline">Logout</span>
                    </button>
                </form>

            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="w-64 h-screen fixed top-0 bg-white border-r hidden md:flex flex-col z-50" style="border-color:rgba(195,197,217,0.3);">
        <div class="h-16 flex flex-col justify-center px-6 border-b" style="border-color:rgba(195,197,217,0.3);">
            <span class="text-xl font-bold tracking-tighter" style="color:#003ec7; letter-spacing:-0.05em;">AVIVANEXT</span>
            <span class="font-semibold uppercase" style="color:#737688; font-size:9px; letter-spacing:0.15em; margin-top:-2px;">Face Recognition API</span>
        </div>
        <div class="p-6">
            <nav class="space-y-1">
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-lg font-medium transition-all" href="/Dashboard" style="transition-duration:200ms;">
                    <span class="material-symbols-outlined">dashboard</span>
                    Dashboard
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-lg font-medium transition-all" href="/AttendanceList" style="transition-duration:200ms;">
                    <span class="material-symbols-outlined">event_available</span>
                    Attendance
                </a>
                <a class="flex items-center gap-3 px-4 py-3 bg-blue-50 rounded-lg font-medium" href="/UserWorkingHoursList" style="color:#003ec7;">
                    <span class="material-symbols-outlined">query_stats</span>
                    Analysis
                </a>
            </nav>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="md:ml-64 pt-8 px-6 pb-20" style="min-height:100vh;">
        <div style="max-width:1200px; margin:0 auto;">

            <!-- Page Header -->
            <div class="mb-12 flex flex-col gap-1">
                <h1 class="font-semibold" style="font-size:32px; line-height:1.2; letter-spacing:-0.01em; color:#131b2e;">User Working Hours</h1>
                <p style="color:#737688;">View and analyze user working hours with flexible filtering options</p>
            </div>

            <!-- Processing Summary -->
            @if (Model.ShowProcessingInfo && Model.ProcessingSummary != null)
            {
                <div class="glass-card rounded-xl p-6 mb-8" style="border-left:4px solid #28a745;">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined" style="color:#28a745; font-variation-settings:'FILL' 1;">check_circle</span>
                        <span class="font-semibold" style="color:#28a745;">Working Hours Processing Summary</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm" style="color:#555;">
                        <div>
                            <span style="color:#28a745; font-weight:600;">@Model.ProcessingSummary.TotalUsersProcessed</span> users processed
                        </div>
                        <div>
                            <span style="color:#ffc107; font-weight:600;">@Model.ProcessingSummary.UsersSkipped</span> users skipped (insufficient records)
                        </div>
                        @if (Model.ProcessingSummary.ProcessedRecords.Any())
                        {
                            <div>
                                <span style="color:#17a2b8; font-weight:600;">@Model.ProcessingSummary.ProcessedRecords.Sum(r => r.RecordsProcessed)</span> attendance records processed
                            </div>
                        }
                    </div>
                    @*
                    @if (Model.ProcessingSummary.ProcessedRecords.Any())
                    {
                        <div class="mt-4 pt-4" style="border-top:1px solid #e0e0e0;">
                            <div class="font-semibold mb-3" style="color:#333; font-size:14px;">Processed Users:</div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                @foreach (var record in Model.ProcessingSummary.ProcessedRecords)
                                {
                                    <div style="background:#f0f9ff; padding:10px; border-radius:8px; font-size:13px;">
                                        <div><strong>@record.UserId</strong> — <strong style="color:#28a745;">@record.WorkingHours:F2 hours</strong></div>
                                        <div style="color:#999; font-size:12px; margin-top:2px;">@record.FirstScanTime.ToString("HH:mm") – @record.LastScanTime.ToString("HH:mm") (@record.RecordsProcessed scans)</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    *@
                </div>
            }

            <!-- Filter Section -->
            <div class="glass-card rounded-xl p-6 mb-8" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">
                <div class="flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined" style="color:#003ec7;">filter_list</span>
                    <h2 class="font-semibold" style="color:#131b2e; font-size:18px;">Filter Records</h2>
                </div>
                <form method="get" asp-page="UserWorkingHoursList">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="flex flex-col gap-2">
                            <label for="startDate" class="text-xs font-semibold uppercase tracking-wider" style="color:#737688;">Start Date</label>
                            <input type="date" id="startDate" name="StartDate"
                                   value="@Model.StartDate?.ToString("yyyy-MM-dd")"
                                   class="px-4 py-3 rounded-lg outline-none text-sm"
                                   style="border:1px solid #c3c5d9; background:#fff; color:#131b2e;" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="endDate" class="text-xs font-semibold uppercase tracking-wider" style="color:#737688;">End Date</label>
                            <input type="date" id="endDate" name="EndDate"
                                   value="@Model.EndDate?.ToString("yyyy-MM-dd")"
                                   class="px-4 py-3 rounded-lg outline-none text-sm"
                                   style="border:1px solid #c3c5d9; background:#fff; color:#131b2e;" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="filterUserId" class="text-xs font-semibold uppercase tracking-wider" style="color:#737688;">User ID</label>
                            <div class="relative">
                                <select id="filterUserId" name="FilterUserId"
                                        class="w-full px-4 py-3 rounded-lg outline-none text-sm appearance-none"
                                        style="border:1px solid #c3c5d9; background:#fff; color:#131b2e;">
                                    <option value="">-- All Users --</option>
                                    @foreach (var user in Model.Users)
                                    {
                                        <option value="@user.UserId" selected="@(Model.FilterUserId == user.UserId)">
                                            @user.UserName
                                        </option>
                                    }
                                </select>
                                <span class="material-symbols-outlined absolute right-3 top-3 pointer-events-none" style="color:#737688; font-size:20px;">expand_more</span>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" name="ViewType" value="@Model.ViewType" />
                    <div class="flex flex-wrap items-center gap-3 mt-8">
                        <button type="submit"
                                class="flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold"
                                style="background:#003ec7; color:#fff;">
                            <span class="material-symbols-outlined" style="font-size:18px;">search</span>
                            Apply Filters
                        </button>
                        <a href="/UserWorkingHoursList"
                               class="flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold"
                               style="border:1px solid #c3c5d9; color:#434656; background:#fff;">
                            <span class="material-symbols-outlined" style="font-size:18px;">close</span>
                            Clear Filters
                        </a>
                    </div>
                </form>
            </div>

            <!-- Filter Status Message -->
            @if (Model.StartDate.HasValue || Model.EndDate.HasValue || !string.IsNullOrWhiteSpace(Model.FilterUserId))
            {
                <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl" style="background:#fffbeb; border:1px solid #fde68a; color:#92400e;">
                    <span class="material-symbols-outlined" style="font-size:20px; font-variation-settings:'FILL' 1;">info</span>
                    <span class="text-sm font-medium">Active filters applied: Viewing filtered records.</span>
                </div>
            }
            else
            {
                <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl" style="background:#eff6ff; border:1px solid #bfdbfe; color:#1d4ed8;">
                    <span class="material-symbols-outlined" style="font-size:20px; font-variation-settings:'FILL' 1;">info</span>
                    <span class="text-sm font-medium">Active filters applied: Currently viewing records from current month.</span>
                </div>
            }

            <!-- View Type Selection -->
            <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider mb-3" style="color:#737688;">Select View Type</h3>
                    <div class="inline-flex p-1 rounded-xl gap-1" style="background:rgba(234,237,255,0.5); border:1px solid rgba(195,197,217,0.3);">
                        <form method="get" asp-page="UserWorkingHoursList" style="display:contents;">
                            <input type="hidden" name="viewType" value="daily" />
                            <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="filterUserId" value="@Model.FilterUserId" />
                            <button type="submit" class="px-5 py-2 rounded-lg text-sm font-semibold transition-all"
                                    style="@(Model.ViewType == "daily" ? "background:#003ec7; color:#fff;" : "color:#737688;")">
                                Daily
                            </button>
                        </form>
                        <form method="get" asp-page="UserWorkingHoursList" style="display:contents;">
                            <input type="hidden" name="viewType" value="weekly" />
                            <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="filterUserId" value="@Model.FilterUserId" />
                            <button type="submit" class="px-5 py-2 rounded-lg text-sm font-semibold transition-all"
                                    style="@(Model.ViewType == "weekly" ? "background:#003ec7; color:#fff;" : "color:#737688;")">
                                Weekly
                            </button>
                        </form>
                        <form method="get" asp-page="UserWorkingHoursList" style="display:contents;">
                            <input type="hidden" name="viewType" value="monthly" />
                            <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="filterUserId" value="@Model.FilterUserId" />
                            <button type="submit" class="px-5 py-2 rounded-lg text-sm font-semibold transition-all"
                                    style="@(Model.ViewType == "monthly" ? "background:#003ec7; color:#fff;" : "color:#737688;")">
                                Monthly
                            </button>
                        </form>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="p-2 rounded-lg" style="color:#737688;">
                        <span class="material-symbols-outlined">download</span>
                    </button>
                    <button class="p-2 rounded-lg" style="color:#737688;">
                        <span class="material-symbols-outlined">print</span>
                    </button>
                </div>
            </div>

            <!-- Table Card -->
            <div class="glass-card rounded-xl overflow-hidden" style="box-shadow:0 4px 20px 0 rgba(0,82,255,0.05);">

                <!-- Table Header -->
                <div class="px-6 py-4 border-b flex items-center gap-3" style="background:#f2f3ff; border-color:#c3c5d9;">
                    <span class="material-symbols-outlined" style="color:#003ec7;">table_rows</span>
                    <h3 class="font-semibold" style="color:#131b2e; font-size:18px;">Records</h3>
                </div>

                <!-- Table -->
                <div class="overflow-x-auto">

                    @if (Model.ViewType == "weekly" && Model.WeeklyWorkingHours.Any())
                    {
                        <table class="w-full text-left">
                            <thead>
                                <tr style="background:rgba(226,231,255,0.5); color:#737688; font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">
                                    <th class="px-6 py-4 font-medium">Week Period</th>
                                    <th class="px-6 py-4 font-medium">User ID</th>
                                    <th class="px-6 py-4 font-medium">User Name</th>
                                    <th class="px-6 py-4 font-medium">Total Hours</th>
                                    <th class="px-6 py-4 font-medium">Days Worked</th>
                                    <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                                </tr>
                            </thead>
                            <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                                @foreach (var record in Model.WeeklyWorkingHours)
                                {
                                    <tr class="hover:bg-blue-50 transition-colors" style="border-bottom:1px solid rgba(195,197,217,0.3);">
                                        <td class="px-6 py-4">
                                            <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium" style="background:#eaedff; color:#003ec7;">@record.WeekPeriod</span>
                                        </td>
                                        <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                                        <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                                        <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                                        <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                                        <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (Model.ViewType == "monthly" && Model.MonthlyWorkingHours.Any())
                    {
                        <table class="w-full text-left">
                            <thead>
                                <tr style="background:rgba(226,231,255,0.5); color:#737688; font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">
                                    <th class="px-6 py-4 font-medium">Month</th>
                                    <th class="px-6 py-4 font-medium">User ID</th>
                                    <th class="px-6 py-4 font-medium">User Name</th>
                                    <th class="px-6 py-4 font-medium">Total Hours</th>
                                    <th class="px-6 py-4 font-medium">Days Worked</th>
                                    <th class="px-6 py-4 font-medium">Avg Hours/Day</th>
                                </tr>
                            </thead>
                            <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                                @foreach (var record in Model.MonthlyWorkingHours)
                                {
                                    <tr class="hover:bg-blue-50 transition-colors" style="border-bottom:1px solid rgba(195,197,217,0.3);">
                                        <td class="px-6 py-4">
                                            <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium" style="background:#eaedff; color:#003ec7;">@record.MonthPeriod</span>
                                        </td>
                                        <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                                        <td class="px-6 py-4" style="color:#131b2e;">@record.UserName</td>
                                        <td class="px-6 py-4 font-semibold" style="color:#131b2e;">@record.TotalHoursFormatted</td>
                                        <td class="px-6 py-4" style="color:#434656;">@record.DaysWorked days</td>
                                        <td class="px-6 py-4 font-semibold" style="color:#00677f;">@record.AverageFormatted</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (Model.ViewType == "daily" && Model.WorkingHoursRecords.Any())
                    {
                        <table class="w-full text-left">
                            <thead>
                                <tr style="background:rgba(226,231,255,0.5); color:#737688; font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">
                                    <th class="px-6 py-4 font-medium">User ID</th>
                                    <th class="px-6 py-4 font-medium">Name</th>
                                    <th class="px-6 py-4 font-medium">Date</th>
                                    <th class="px-6 py-4 font-medium">Working Hours</th>
                                </tr>
                            </thead>
                            <tbody style="border-top:1px solid rgba(195,197,217,0.3);">
                                @foreach (var record in Model.WorkingHoursRecords)
                                {
                                    <tr class="hover:bg-blue-50 transition-colors" style="border-bottom:1px solid rgba(195,197,217,0.3);">
                                        <td class="px-6 py-4 font-medium" style="color:#003ec7;">@record.UserId</td>
                                        <td class="px-6 py-4" style="color:#131b2e;">@record.Name</td>
                                        <td class="px-6 py-4" style="color:#434656;">@record.LoginDateFormatted</td>
                                        <td class="px-6 py-4">
                                            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium" style="background:#f0fdf4; color:#15803d;">
                                                <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#16a34a;"></span>
                                                @record.WorkingHoursFormatted
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-16" style="color:#737688;">
                            <span class="material-symbols-outlined" style="font-size:48px; color:#c3c5d9; display:block; margin-bottom:12px;">search_off</span>
                            <h3 class="font-semibold mb-1" style="color:#434656;">No Records Found</h3>
                            <p class="text-sm">No working hours records match your current filters.</p>
                        </div>
                    }

                </div>

                <!-- Table Footer -->
                <div class="px-6 py-4 border-t flex justify-between items-center" style="background:#f2f3ff; border-color:#c3c5d9;">
                    <span class="text-xs font-medium" style="color:#737688;">
                        @{
                            var count = Model.ViewType == "weekly" ? Model.WeeklyWorkingHours.Count
                                      : Model.ViewType == "monthly" ? Model.MonthlyWorkingHours.Count
                                      : Model.WorkingHoursRecords.Count;
                        }
                        Showing @count entries
                    </span>                    
                </div>
            </div>

        </div>
    </main>

    <!-- Bottom Navigation (Mobile only) -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center h-20 px-4 border-t rounded-t-2xl shadow-lg"
         style="background:rgba(255,255,255,0.95); backdrop-filter:blur(16px); border-color:rgba(195,197,217,0.2);">
        <a class="flex flex-col items-center justify-center text-slate-400 text-xs uppercase font-medium" style="letter-spacing:0.1em;" href="/">
            <span class="material-symbols-outlined">home</span>
            <span>Home</span>
        </a>
        <a class="flex flex-col items-center justify-center text-slate-400 text-xs uppercase font-medium" style="letter-spacing:0.1em;" href="/AttendanceList">
            <span class="material-symbols-outlined">event_available</span>
            <span>Attendance</span>
        </a>
        <a class="flex flex-col items-center justify-center text-xs uppercase font-medium" style="color:#003ec7; letter-spacing:0.1em; transform:scale(1.1);" href="/UserWorkingHoursList">
            <span class="material-symbols-outlined">query_stats</span>
            <span>Analysis</span>
        </a>
    </nav>

</body>
</html>
